---
// src/layouts/ArtisticLayout.astro
export const templateMeta = {
  id: 'artistic',
  name: 'Artístico',
  svg: `<svg viewBox="0 0 100 125" class="w-full h-full select-none" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="100" height="125" rx="6" fill="#faf6f0" stroke="#e3dac9" stroke-width="1.5"/>
    <path d="M8,18 C8,12 11,8 17,8 C22,8 24,11 24,17 C24,22 21,24 16,24 C11,24 8,23 8,18 Z" fill="#ffffff" stroke="#8c7864" stroke-width="1.2"/>
    <rect x="28" y="11" width="48" height="4" rx="1" fill="#2e2924"/>
    <rect x="28" y="19" width="32" height="2.5" rx="0.5" fill="#a67c52"/>
    <rect x="8" y="38" width="22" height="2.5" rx="0.5" fill="#8c7864"/>
    <line x1="8" y1="42" x2="35" y2="42" stroke="#e3dac9" stroke-width="0.75"/>
    <rect x="8" y="47" width="84" height="2" rx="0.5" fill="#d6cbb7"/>
    <rect x="8" y="52" width="70" height="2" rx="0.5" fill="#d6cbb7"/>
    <rect x="8" y="60" width="26" height="2.5" rx="0.5" fill="#8c7864"/>
    <line x1="8" y1="64" x2="35" y2="64" stroke="#e3dac9" stroke-width="0.75"/>
    <rect x="8" y="69" width="50" height="2.5" rx="0.5" fill="#2e2924"/>
    <rect x="8" y="75" width="84" height="2" rx="0.5" fill="#d6cbb7"/>
    <rect x="8" y="86" width="22" height="2.5" rx="0.5" fill="#8c7864"/>
    <rect x="8" y="94" width="16" height="4" rx="2" fill="#f1eae1" stroke="#e3dac9" stroke-width="0.5"/>
    <rect x="28" y="94" width="20" height="4" rx="2" fill="#f1eae1" stroke="#e3dac9" stroke-width="0.5"/>
    <rect x="52" y="94" width="18" height="4" rx="2" fill="#f1eae1" stroke="#e3dac9" stroke-width="0.5"/>
  </svg>`
};

interface Props {
  title: string;
  description: string;
  lang: string;
  currentLang: string;
  availableLangs: string[];
  resume: any;
  t: (key: string) => string;
}

const { title, description, lang, currentLang, availableLangs, resume, t } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#faf6f0] artistic-layout min-h-screen text-stone-800 antialiased font-sans">
  <main class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16 print:p-0 min-w-0" style="overflow-wrap:anywhere">
    <slot />
  </main>
</body>
</html>

<style is:global>
  /* 🎨 ESTILOS ARTÍSTICOS CÁLIDOS */
  body.artistic-layout, [data-template="artistic"] {
    background-color: #faf6f0 !important;
    color: #443e38 !important;
  }

  body.artistic-layout header, [data-template="artistic"] #preview-header {
    display: flex !important;
    align-items: start !important;
    justify-content: flex-start !important;
    gap: 1.75rem !important;
  }
  
  body.artistic-layout header img, [data-template="artistic"] #preview-header img {
    order: -1 !important;
    border-radius: 60% 40% 60% 40% / 40% 60% 40% 60% !important;
    border: 2px solid #8c7864 !important;
    padding: 3px !important;
    background-color: #ffffff;
  }

  body.artistic-layout h2, [data-template="artistic"] #view-name {
    font-family: 'Playfair Display', Georgia, serif !important;
    color: #2e2924 !important;
    font-size: 2.1rem !important;
    font-style: italic !important;
  }

  body.artistic-layout h3, [data-template="artistic"] h3 {
    font-family: 'Playfair Display', Georgia, serif !important;
    color: #8c7864 !important;
    font-size: 1rem !important;
    letter-spacing: 0.025em !important;
    border-bottom: 1px solid #e3dac9 !important;
  }

  body.artistic-layout .badge-item-live, [data-template="artistic"] .badge-item-live {
    background-color: #f1eae1 !important;
    color: #6e5d4f !important;
    border: 1px solid #e3dac9 !important;
    border-radius: 9999px !important;
    font-style: italic !important;
    font-size: 0.75rem !important;
  }

  body.artistic-layout .text-blue-600, [data-template="artistic"] .text-blue-600 {
    color: #a67c52 !important;
    font-weight: 600 !important;
  }
  body.artistic-layout .text-gray-500, [data-template="artistic"] .text-gray-500 {
    color: #8c8276 !important;
  }
</style>