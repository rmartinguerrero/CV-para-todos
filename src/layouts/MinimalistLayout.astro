---
// src/layouts/MinimalistLayout.astro
export const templateMeta = {
  id: 'minimalist',
  name: 'Minimalista',
  svg: `<svg viewBox="0 0 100 125" class="w-full h-full select-none" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect width="100" height="125" rx="6" fill="#ffffff" stroke="#e2e8f0" stroke-width="1.5"/>
    <rect x="8" y="10" width="16" height="16" rx="2" fill="#e2e8f0"/>
    <rect x="28" y="12" width="45" height="4" rx="1" fill="#94a3b8"/>
    <rect x="28" y="20" width="30" height="2.5" rx="0.5" fill="#cbd5e1"/>
    <line x1="8" y1="32" x2="92" y2="32" stroke="#f1f5f9" stroke-width="1"/>
    <rect x="8" y="38" width="20" height="3" rx="0.5" fill="#cbd5e1"/>
    <rect x="8" y="45" width="84" height="2" rx="0.5" fill="#f1f5f9"/>
    <rect x="8" y="50" width="75" height="2" rx="0.5" fill="#f1f5f9"/>
    <rect x="8" y="58" width="25" height="3" rx="0.5" fill="#cbd5e1"/>
    <rect x="8" y="66" width="40" height="2.5" rx="0.5" fill="#94a3b8"/>
    <rect x="8" y="72" width="84" height="2" rx="0.5" fill="#f1f5f9"/>
    <rect x="8" y="77" width="50" height="2" rx="0.5" fill="#f1f5f9"/>
    <rect x="8" y="86" width="25" height="3" rx="0.5" fill="#cbd5e1"/>
    <rect x="8" y="94" width="18" height="4" rx="1" fill="#e2e8f0"/>
    <rect x="30" y="94" width="22" height="4" rx="1" fill="#e2e8f0"/>
    <rect x="56" y="94" width="15" height="4" rx="1" fill="#e2e8f0"/>
  </svg>`
};

interface Props {
  title: string;
  description: string;
  lang: string;
  resume: any;
  t: (key: string) => string;
}

const { title, description, lang, resume, t } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-white minimalist-layout min-h-screen text-gray-900 antialiased font-sans pdf-page">
  <main class="max-w-3xl mx-auto px-6 py-12 sm:py-16 print:p-0">
    <slot />
  </main>
</body>
</html>

<style is:global>
  @media print {
    body { background: white; color: black; }
    .print\:hidden { display: none !important; }
  }

  body.minimalist-layout header, [data-template="minimalist"] #preview-header {
    display: flex !important;
    align-items: start !important;
    justify-content: flex-start !important;
    gap: 1.5rem !important;
  }
  body.minimalist-layout header img, [data-template="minimalist"] #preview-header img {
    order: -1 !important;
  }
</style>