---
interface Props {
  title:          string;
  description:    string;
  lang:           string;
  currentLang:    string;
  availableLangs: string[];
  resume:         any;
  t:              (key: string) => string;
}

const { title, description, lang, resume } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = resume?.basics?.image || '';

// EXPORTS COLOCADOS AL FINAL DEL FRONTMATTER PARA EVITAR COMPORTAMIENTOS EXTRAÑOS EN ASTRO.GLOB
export const templateId = 'minimal';
export const templateName = 'templates.minimallayout.name';
export const templateSvg = `<svg viewBox="0 0 100 120" class="w-full h-full text-gray-700"><rect width="100" height="120" rx="8" fill="#ffffff" stroke="currentColor" stroke-width="2"/><line x1="15" y1="20" x2="60" y2="20" stroke="currentColor" stroke-width="4"/><line x1="15" y1="35" x2="85" y2="35" stroke="currentColor" stroke-width="1"/><line x1="15" y1="50" x2="85" y2="50" stroke="currentColor" stroke-width="1"/><line x1="15" y1="65" x2="50" y2="65" stroke="currentColor" stroke-width="1"/></svg>`;
---
<!DOCTYPE html>
<html lang={lang} translate="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
  <style is:global>
    @media print {
      .print\:hidden { display: none !important; }
      .print\:block { display: block !important; }
      .print\:p-0 { padding: 0 !important; }
      #preview-section { width: 100% !important; border: 0 !important; padding: 0 !important; box-shadow: none !important; min-height: auto !important; }
    }
  </style>
</head>
<body class="bg-gray-50 text-gray-900 antialiased min-h-screen">
  <slot />
</body>
</html>