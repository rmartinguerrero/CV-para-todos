---
// src/pages/index.astro
// Detecta el idioma del navegador y redirige al CV correcto
import { languages, defaultLang, getAvailableLangs } from '../i18n/ui';
import resumeEs from '../data/resume.es.json';
import resumeIt from '../data/resume.it.json';
import resumeEn from '../data/resume.en.json';

const resumes = { es: resumeEs, it: resumeIt, en: resumeEn };
const available = getAvailableLangs(resumes);

// Si solo hay un idioma con datos, redirigir directamente
const target = available.length === 1
  ? available[0]
  : defaultLang;
---
<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Redirigiendo…</title>
  <script define:vars={{ available, defaultLang: target }}>
    // Detección de idioma en el cliente
    const preferred = navigator.languages
      .map(l => l.split('-')[0])
      .find(l => available.includes(l));
    const lang = preferred ?? defaultLang;
    window.location.replace(`/${lang}/`);
  </script>
  <noscript>
    <meta http-equiv="refresh" content={`0; url=/${target}/`} />
  </noscript>
</head>
<body></body>
</html>
