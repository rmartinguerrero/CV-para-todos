---
// src/pages/index.astro
import SetupWizard from '../components/SetupWizard.astro';
import resumeEs from '../data/resume.es.json';
import resumeIt from '../data/resume.it.json';
import resumeEn from '../data/resume.en.json';

// Comprobamos si el proyecto está completamente vacío en todos los idiomas
const isBrandNew = !resumeEs.basics?.name && !resumeIt.basics?.name && !resumeEn.basics?.name;
---

{isBrandNew ? (
  /* Si la web es totalmente nueva y no tiene datos, le forzamos a configurarla en español de entrada */
  <SetupWizard availableLangs={['es', 'it', 'en']} defaultLang="es" />
) : (
  /* Si ya hay datos, detectamos el idioma del sistema operativo del usuario en el navegador */
  <html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Redirecting…</title>
    <script>
      const available = ['es', 'it', 'en'];
      
      const preferred = navigator.languages
        .map(l => l.split('-')[0])
        .find(l => available.includes(l));
      
      // Si el SO está en español o italiano va allí. Cualquier otra cosa va a inglés (/en/)
      const targetLang = preferred ?? 'en';
      window.location.replace(`/${targetLang}/`);
    </script>
    <noscript>
      <meta http-equiv="refresh" content="0; url=/en/" />
    </noscript>
  </head>
  <body class="bg-white"></body>
  </html>
)}