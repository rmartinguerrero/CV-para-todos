---
// src/pages/index.astro
// Forzamos un documento en blanco absoluto. Las cabeceras hacen el resto.
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content="0;url=/es" />
  <title>Loading</title>
  
  {/* En Astro, para dejar un script tal cual en el HTML sin procesar, se usa 'is:inline' */}
  <script is:inline>
    const available = ['es', 'it', 'en'];
    const preferred = navigator.languages
      .map(l => l.split('-')[0])
      .find(l => available.includes(l)) || 'en';
    window.location.replace('/' + preferred);
  </script>
</head>
<body class="bg-white dark:bg-slate-900">
  </body>
</html>