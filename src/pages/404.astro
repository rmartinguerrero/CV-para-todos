---
import MinimalistLayout from '../layouts/MinimalistLayout.astro';
---

<MinimalistLayout
  title="404"
  description="404"
  lang="en"
  currentLang="en"
  availableLangs={['en']}
  resume={{}}
  t={(k: string) => k}
>

<style is:global>
  body:has(.nf-page) main {
    max-width: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }
  body:has(.nf-page) {
    overflow: hidden;
  }
  body:has(.nf-page), body:has(.nf-page) .minimalist-layout {
    background: #f4f1eb;
  }
</style>

<svg aria-hidden="true" style="position:absolute;width:0;height:0;overflow:hidden">
  <defs>
    <filter id="cshadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="6" stdDeviation="12" flood-color="rgba(0,0,0,0.06)"/>
    </filter>
    <g id="cloud">
      <path d="M 35 105 C 8 105, 6 80, 22 67 C 18 45, 42 32, 62 38 C 72 14, 118 12, 138 35 C 158 18, 200 22, 210 48 C 230 48, 235 72, 218 90 C 228 104, 215 105, 200 105 Z" fill="rgba(255,255,255,0.7)" filter="url(#cshadow)"/>
      <rect x="36" y="48" width="22" height="22" rx="3" fill="rgba(200,200,215,0.2)" stroke="rgba(0,0,0,0.04)" stroke-width="0.5"/>
      <rect x="64" y="51" width="148" height="3" rx="1.5" fill="rgba(0,0,0,0.04)"/>
      <rect x="64" y="59" width="118" height="3" rx="1.5" fill="rgba(0,0,0,0.03)"/>
      <rect x="36" y="76" width="180" height="3" rx="1.5" fill="rgba(0,0,0,0.04)"/>
      <rect x="36" y="84" width="145" height="3" rx="1.5" fill="rgba(0,0,0,0.03)"/>
      <rect x="36" y="92" width="100" height="3" rx="1.5" fill="rgba(0,0,0,0.035)"/>
    </g>
    <g id="tumbleweed">
      <g fill="none" stroke="#b8956a" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" opacity="0.8">
        <path d="M 10 30 C 12 10, 28 6, 30 8 C 42 12, 50 22, 50 28 C 52 42, 42 52, 35 52 C 22 54, 10 46, 10 30"/>
        <path d="M 8 25 C 14 12, 24 10, 32 15 C 42 18, 50 28, 52 35 C 54 48, 42 54, 40 52 C 28 56, 14 48, 8 25"/>
        <path d="M 14 16 C 22 8, 34 4, 45 14 C 52 22, 56 32, 46 44 C 40 52, 28 56, 20 48 C 12 40, 10 24, 14 16"/>
        <path d="M 6 35 C 10 22, 20 16, 30 18 C 38 18, 44 22, 48 30"/>
        <path d="M 12 42 C 18 30, 28 26, 38 28 C 46 30, 50 34, 50 42"/>
        <path d="M 18 8 C 26 4, 36 6, 42 12 C 48 16, 50 22, 50 28"/>
        <path d="M 30 54 C 38 52, 46 46, 48 40"/>
        <path d="M 8 40 C 6 34, 8 28, 12 22"/>
        <path d="M 22 25 C 26 16, 32 14, 38 20"/>
        <path d="M 38 42 C 42 34, 46 28, 48 22"/>
        <path d="M 20 8 C 28 6, 36 8, 40 14 C 44 18, 46 24, 44 30"/>
      </g>
      <g fill="none" stroke="#a87d4a" stroke-width="0.8" stroke-linecap="round" opacity="0.3">
        <path d="M 16 34 C 20 38, 26 40, 30 38"/>
        <path d="M 34 12 C 38 16, 40 22, 38 26"/>
        <path d="M 42 46 C 46 40, 46 34, 44 30"/>
        <path d="M 20 20 C 24 16, 28 14, 32 20"/>
      </g>
    </g>
  </defs>
</svg>

<div class="nf-page">
  <div class="nf-sky"></div>

  <div class="nf-clouds" aria-hidden="true">
    <svg class="nf-cloud" viewBox="0 0 240 130" style="--top:6;--dur:50;--delay:0;--op:0.55;--sc:1" aria-hidden="true"><use href="#cloud"/></svg>
    <svg class="nf-cloud" viewBox="0 0 240 130" style="--top:15;--dur:72;--delay:-12;--op:0.5;--sc:0.85" aria-hidden="true"><use href="#cloud"/></svg>
    <svg class="nf-cloud" viewBox="0 0 240 130" style="--top:26;--dur:82;--delay:-28;--op:0.4;--sc:1.1" aria-hidden="true"><use href="#cloud"/></svg>
    <svg class="nf-cloud" viewBox="0 0 240 130" style="--top:38;--dur:58;--delay:-6;--op:0.55;--sc:0.75" aria-hidden="true"><use href="#cloud"/></svg>
    <svg class="nf-cloud" viewBox="0 0 240 130" style="--top:48;--dur:68;--delay:-38;--op:0.45;--sc:0.9" aria-hidden="true"><use href="#cloud"/></svg>
    <svg class="nf-cloud" viewBox="0 0 240 130" style="--top:60;--dur:48;--delay:-16;--op:0.6;--sc:0.8" aria-hidden="true"><use href="#cloud"/></svg>
    <svg class="nf-cloud" viewBox="0 0 240 130" style="--top:70;--dur:92;--delay:-48;--op:0.35;--sc:1.15" aria-hidden="true"><use href="#cloud"/></svg>
    <svg class="nf-cloud" viewBox="0 0 240 130" style="--top:82;--dur:42;--delay:-22;--op:0.5;--sc:0.7" aria-hidden="true"><use href="#cloud"/></svg>
  </div>

  <div class="nf-content">
    <h1 class="nf-404">404</h1>
    <p class="nf-msg">Ooooops!</p>
    <a class="nf-btn" href="/">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Back to Home
    </a>
  </div>

  <div class="nf-desert" aria-hidden="true">
    <div class="nf-cactus" style="--h:45;--x:8;--arm1:18;--arm2:10;--arm1l:10;--arm2l:9;--s:1"></div>
    <div class="nf-cactus" style="--h:55;--x:78;--arm1:22;--arm2:14;--arm1l:11;--arm2l:10;--s:1.15"></div>
    <div class="nf-cactus" style="--h:35;--x:55;--arm1:14;--arm2:0;--arm1l:8;--arm2l:0;--s:0.85"></div>
    <div class="nf-tw-track">
      <svg class="nf-tw" viewBox="0 0 60 60" aria-hidden="true"><use href="#tumbleweed"/></svg>
    </div>
  </div>
</div>

<style>
  .nf-page {
    position: relative;
    height: 80vh;
    min-height: 420px;
    width: 100%;
    overflow: hidden;
    background: linear-gradient(175deg, #e8eef5 0%, #f4f1eb 45%, #ede7dc 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nf-sky {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 35% at 50% 0%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(ellipse 40% 25% at 30% 10%, rgba(255,240,210,0.3) 0%, transparent 100%);
    pointer-events: none;
  }

  /* ── Clouds ── */
  .nf-clouds {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .nf-cloud {
    position: absolute;
    width: calc(var(--w, 240) * 1px);
    height: calc(var(--h, 130) * 1px);
    top: calc(var(--top) * 1%);
    opacity: var(--op, 0.5);
    animation: drift calc(var(--dur) * 1s) linear calc(var(--delay) * 1s) infinite;
    will-change: transform;
  }

  @keyframes drift {
    0% { transform: scale(var(--sc, 1)) translateX(calc(100vw + 200px)); }
    100% { transform: scale(var(--sc, 1)) translateX(calc(-100vw - 300px)); }
  }

  /* ── Content ── */
  .nf-content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 1.5rem;
    max-width: 400px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    pointer-events: none;
  }

  .nf-content * {
    pointer-events: auto;
  }

  .nf-404 {
    font-size: 8rem;
    font-weight: 800;
    line-height: 1;
    color: #1e293b;
    margin: 0;
    letter-spacing: -0.03em;
    animation: fadeSlide 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .nf-msg {
    font-size: 1.15rem;
    font-weight: 600;
    color: #64748b;
    margin: 0.6rem 0 1.75rem;
    letter-spacing: 0.02em;
    animation: fadeSlide 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.15s both;
  }

  @keyframes fadeSlide {
    0% { opacity: 0; transform: translateY(16px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  .nf-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    border-radius: 9999px;
    background: #0f172a;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    animation: fadeSlide 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.3s both;
  }

  .nf-btn:hover {
    background: #1e293b;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(15, 23, 42, 0.15);
  }

  .nf-btn:focus-visible {
    outline: 2px solid #6366f1;
    outline-offset: 3px;
  }

  .nf-btn:active {
    transform: translateY(0);
  }

  .nf-btn svg {
    flex-shrink: 0;
  }

  /* ── Desert ground ── */
  .nf-desert {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 90px;
    background: linear-gradient(to top, #e2d6c4 0%, rgba(226, 214, 196, 0.6) 50%, transparent 100%);
    pointer-events: none;
  }

  .nf-desert::before {
    content: '';
    position: absolute;
    bottom: 28px;
    left: 0;
    right: 0;
    height: 1px;
    background: rgba(0, 0, 0, 0.06);
  }

  /* ── Cactus ── */
  .nf-cactus {
    position: absolute;
    bottom: 28px;
    left: calc(var(--x) * 1%);
    width: 12px;
    height: calc(var(--h) * 1px);
    background: #4a8c5c;
    border-radius: 6px 6px 2px 2px;
    transform: scaleX(var(--s, 1));
  }

  .nf-cactus::before {
    content: '';
    position: absolute;
    top: calc(var(--arm1) * 1px);
    left: -12px;
    width: calc(var(--arm1l) * 1px);
    height: 6px;
    background: #4a8c5c;
    border-radius: 0 3px 3px 0;
  }

  .nf-cactus::after {
    content: '';
    position: absolute;
    top: calc(var(--arm2) * 1px);
    right: -12px;
    width: calc(var(--arm2l) * 1px);
    height: 6px;
    background: #4a8c5c;
    border-radius: 3px 0 0 3px;
  }

  /* ── Tumbleweed ── */
  .nf-tw-track {
    position: absolute;
    bottom: 38px;
    left: 0;
    width: 100%;
    height: 0;
    animation: track 16s cubic-bezier(0.42, 0, 0.58, 1) infinite;
  }

  .nf-tw {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 34px;
    height: 34px;
    animation: spin 16s linear infinite;
  }

  @keyframes track {
    0% { transform: translateX(calc(100vw + 50px)) translateY(0); }
    15% { transform: translateX(calc(85vw)) translateY(-7px); }
    30% { transform: translateX(calc(70vw)) translateY(0); }
    45% { transform: translateX(calc(50vw)) translateY(-4px); }
    60% { transform: translateX(calc(30vw)) translateY(0); }
    75% { transform: translateX(calc(15vw)) translateY(-5px); }
    100% { transform: translateX(calc(-50px)) translateY(0); }
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(1440deg); }
  }

  /* ── Responsive ── */
  @media (max-width: 480px) {
    .nf-404 { font-size: 5.5rem; }
    .nf-msg { font-size: 1rem; margin: 0.4rem 0 1.5rem; }
    .nf-btn { font-size: 0.85rem; padding: 0.65rem 1.3rem; }
    .nf-cloud { display: none; }
    .nf-cloud:nth-child(-n+4) { display: block; }
    .nf-cactus { display: none; }
    .nf-cactus:first-child { display: block; }
    .nf-tw { width: 26px; height: 26px; }
    .nf-tw-track { bottom: 32px; }
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .nf-404 { font-size: 7rem; }
    .nf-msg { font-size: 1.1rem; }
  }

  @media (max-height: 500px) {
    .nf-page { height: 100vh; min-height: 400px; }
    .nf-404 { font-size: 4rem; }
    .nf-msg { font-size: 0.9rem; margin: 0.3rem 0 1rem; }
    .nf-btn { font-size: 0.8rem; padding: 0.5rem 1.1rem; }
    .nf-cloud { display: none; }
    .nf-cloud:first-child { display: block; }
    .nf-cactus { display: none; }
    .nf-desert { height: 60px; }
    .nf-desert::before { bottom: 18px; }
    .nf-tw { width: 22px; height: 22px; }
    .nf-tw-track { bottom: 26px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .nf-cloud, .nf-tw-track, .nf-tw { animation: none !important; }
    .nf-cloud { opacity: calc(var(--op, 0.5) * 0.5); }
    .nf-tw { left: 90%; width: 30px; height: 30px; opacity: 0.4; }
    .nf-404, .nf-msg, .nf-btn { animation: none; opacity: 1; transform: none; }
  }

  @media print {
    .nf-page { height: auto; min-height: auto; background: none; }
    .nf-clouds, .nf-desert, .nf-sky { display: none; }
    .nf-content { padding: 2rem 0; }
    .nf-404, .nf-msg, .nf-btn { animation: none; opacity: 1; transform: none; }
    .nf-btn { background: #000; color: #fff; }
  }
</style>

</MinimalistLayout>
