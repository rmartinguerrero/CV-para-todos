---
// src/pages/[lang]/edit.astro
import { useTranslations, type Lang, type UIKeys } from '../../i18n/ui';
import resumeEs from '../../data/resume.es.json';
import resumeIt from '../../data/resume.it.json';
import resumeEn from '../../data/resume.en.json';

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const resumes = { es: resumeEs, it: resumeIt, en: resumeEn };
const initialData = resumes[lang] || resumeEs;

// 🎯 Traducciones estrictas desde tu ui.ts
const strictT = useTranslations(lang);
const t = (key: string) => strictT(key as UIKeys);

// 📂 DETECCIÓN AUTOMÁTICA REAL DE PLANTILLAS (Eager Loading desde Vite/Astro)
// Importamos los archivos cargando su contenido interior en tiempo de compilación
const layoutModules = import.meta.glob('../../layouts/*.astro', { eager: true });

const templates = Object.entries(layoutModules)
  .map(([path, mod]: [string, any]) => {
    // Si el layout no exporta metadatos explícitos para el sistema de CVs, lo descartamos elegantemente
    if (!mod.templateMeta) return null;

    return {
      id: mod.templateMeta.id,
      displayName: mod.templateMeta.name,
      svg: mod.templateMeta.svg
    };
  })
  .filter(Boolean) as { id: string; displayName: string; svg: string }[];
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{t('edit.title')}</title>

  <!-- Google Fonts for theme layouts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet" />

  <!-- Cookie Consent + Google Analytics (RGPD) -->
  <script is:inline>
    (() => {
      const consent = localStorage.getItem('cookie-consent');
      if (consent !== 'accepted') return;

      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;

      gtag('js', new Date());
      gtag('config', 'G-R3TG90C8J5', { anonymize_ip: true });

      const gaScript = document.createElement('script');
      gaScript.async = true;
      gaScript.src = "https://www.googletagmanager.com/gtag/js?id=G-R3TG90C8J5";
      const firstScript = document.getElementsByTagName('script')[0];
      firstScript.parentNode.insertBefore(gaScript, firstScript);
    })();
  </script>
</head>
<body class="bg-gray-50 min-h-screen text-gray-800 antialiased">

  <div class="w-full bg-white border-b border-gray-200 sticky top-0 z-50 print:hidden shadow-sm">
    <!-- Desktop header: mantengo el diseño anterior en pantallas grandes -->
    <div class="hidden lg:flex items-center justify-between gap-4 py-2.5 px-4 sm:px-6">
      <a href={`/${lang}`} class="flex items-center gap-2">
        <div class="bg-blue-600 text-white p-2 rounded-lg shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="flex flex-col items-start">
          <span class="text-sm font-black tracking-tight text-gray-900 leading-none">{t('brand.name')}</span>
          <span class="text-[10px] font-bold text-blue-600 uppercase tracking-wider mt-0.5">no code</span>
        </div>
      </a>

      <div class="inline-flex rounded-xl bg-gray-100 p-0.5 border border-gray-200 shadow-inner">
        <button onclick="window.location.href='/es/edit'" class={`px-3 py-1 rounded-lg text-[11px] font-bold transition-all ${lang === 'es' ? 'bg-white text-gray-900 shadow-xs border border-gray-200/60' : 'text-gray-500 hover:text-gray-900'}`}><span class="hidden xl:inline">🇪🇸&nbsp;</span>ES</button>
        <button onclick="window.location.href='/it/edit'" class={`px-3 py-1 rounded-lg text-[11px] font-bold transition-all ${lang === 'it' ? 'bg-white text-gray-900 shadow-xs border border-gray-200/60' : 'text-gray-500 hover:text-gray-900'}`}><span class="hidden xl:inline">🇮🇹&nbsp;</span>IT</button>
        <button onclick="window.location.href='/en/edit'" class={`px-3 py-1 rounded-lg text-[11px] font-bold transition-all ${lang === 'en' ? 'bg-white text-gray-900 shadow-xs border border-gray-200/60' : 'text-gray-500 hover:text-gray-900'}`}><span class="hidden xl:inline">🇺🇸&nbsp;</span>EN</button>
      </div>

      <div class="flex items-center gap-2">
        <button id="btn-download-json" class="btn-download-json-control px-3 py-1.5 text-xs font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg border border-gray-200">{t('edit.downloadJson')}</button>
        <button id="btn-print" class="btn-print-control px-3 py-1.5 text-xs font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg border border-gray-200">{t('edit.downloadPdf')}</button>
        <button id="btn-github-auth" class="btn-github-auth-control px-3 py-1.5 text-xs font-semibold text-white bg-gray-800 hover:bg-gray-900 rounded-lg border border-gray-700 transition-all flex items-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span id="github-status-text" class="github-status-text">GitHub</span>
        </button>
      </div>
    </div>

    <!-- Mobile header: dos barras apiladas para smartphone/tablet -->
    <div class="lg:hidden">
      <div class="flex flex-wrap items-center justify-between gap-3 py-2.5 px-4 sm:px-6">
        <a href={`/${lang}`} class="flex items-center gap-2 flex-1 min-w-0">
          <div class="bg-blue-600 text-white p-1.5 rounded-lg items-center justify-center shadow-sm inline-flex">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <span class="text-sm font-semibold text-gray-900 truncate">{t('brand.name')}</span>
        </a>
        <button class="btn-print-control px-3 py-2 text-xs font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg border border-gray-200">{t('edit.downloadPdf')}</button>
      </div>
      <div class="flex flex-wrap items-center justify-between gap-3 border-t border-gray-100 py-2.5 px-4 sm:px-6">
        <button class="btn-download-json-control w-full sm:w-auto px-3 py-2 text-xs font-semibold text-gray-700 bg-gray-100 hover:bg-gray-200 rounded-lg border border-gray-200">{t('edit.downloadJson')}</button>
        <button class="btn-github-auth-control w-full sm:w-auto px-3 py-2 text-xs font-semibold text-white bg-gray-800 hover:bg-gray-900 rounded-lg border border-gray-700 transition-all flex items-center justify-center gap-1.5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span class="github-status-text">GitHub</span>
        </button>
      </div>
    </div>
  </div>

  <div class="grid lg:grid-cols-2 gap-8 items-start min-h-[calc(100vh-4rem)] p-4 sm:p-6 print:block print:p-0">
    
    <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm space-y-6 print:hidden sticky top-20 max-h-[82vh] overflow-y-auto">
      
      <div class="flex items-center justify-between border-b border-gray-100 pb-2">
        <h1 class="text-lg font-bold text-gray-900 tracking-tight">{t('edit.title')}</h1>
      </div>

      <div class="relative">
        <button id="tab-prev" type="button" class="lg:hidden absolute left-0 top-1/2 z-10 -translate-y-1/2 rounded-full border border-gray-200 bg-white/90 px-2 py-1 text-sm text-gray-600 shadow-sm transition hover:bg-gray-100" aria-label="Anterior sección">‹</button>
        <nav id="tab-nav" class="flex text-xs sm:text-sm overflow-x-auto whitespace-nowrap scroll-smooth px-10" aria-label="Tabs">
          <button class="tab-btn px-4 py-2 border-b-2 border-blue-600 font-medium text-blue-600" data-tab="basics">{t('nav.contact')}</button>
          <button class="tab-btn px-4 py-2 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700" data-tab="work">{lang === 'es' ? 'Experiencia' : lang === 'it' ? 'Esperienza' : 'Experience'}</button>
          <button class="tab-btn px-4 py-2 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700" data-tab="education">{lang === 'es' ? 'Formación' : lang === 'it' ? 'Formazione' : 'Education'}</button>
          <button class="tab-btn px-4 py-2 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700" data-tab="extras">{lang === 'es' ? 'Formación extra' : lang === 'it' ? 'Formazione extra' : 'Extra training'}</button>
          <button class="tab-btn px-4 py-2 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700" data-tab="skills">{lang === 'es' ? 'Habilidades' : lang === 'it' ? 'Competenze' : 'Skills'}</button>
          <button class="tab-btn px-4 py-2 border-b-2 border-transparent font-medium text-gray-500 hover:text-gray-700" data-tab="templates">{t('templates.title')}</button>
        </nav>
        <button id="tab-next" type="button" class="lg:hidden absolute right-0 top-1/2 z-10 -translate-y-1/2 rounded-full border border-gray-200 bg-white/90 px-2 py-1 text-sm text-gray-600 shadow-sm transition hover:bg-gray-100" aria-label="Siguiente sección">›</button>
      </div>

      <div id="cv-form" class="space-y-6">
        <div id="tab-basics" class="tab-content space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">{t('form.name')}</label>
              <input type="text" data-path="basics.name" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-blue-500" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">{t('form.label')}</label>
              <input type="text" data-path="basics.label" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-blue-500" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">Email</label>
              <input type="email" data-path="basics.email" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-blue-500" />
            </div>
            <div>
              <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">{lang === 'es' ? 'Teléfono' : lang === 'it' ? 'Telefono' : 'Phone'}</label>
              <input type="tel" data-path="basics.phone" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-blue-500" />
            </div>
          </div>
          <div class="mt-3">
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">{t('form.website')}</label>
            <input type="url" data-path="basics.web" placeholder="https://" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-blue-500" />
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">{lang === 'es' ? 'Fotografía' : lang === 'it' ? 'Fotografia' : 'Photo'}</label>
            <div class="flex items-center gap-3 bg-gray-50 p-3 rounded-xl border border-dashed border-gray-300">
              <input type="file" id="photo-file" accept="image/*" class="hidden" />
              <button type="button" onclick="document.getElementById('photo-file').click()" class="px-3 py-1.5 bg-white border border-gray-200 text-gray-700 text-xs font-medium rounded-lg hover:bg-gray-50 shadow-sm">
                {lang === 'es' ? 'Seleccionar archivo' : lang === 'it' ? 'Seleziona file' : 'Choose file'}
              </button>
              <button type="button" id="btn-remove-photo" class="text-xs text-red-500 font-medium hidden hover:underline">{lang === 'es' ? 'Eliminar' : lang === 'it' ? 'Elimina' : 'Remove'}</button>
              <span id="photo-status" class="text-xs text-gray-400 truncate max-w-[180px]">{lang === 'es' ? 'Sin archivo' : lang === 'it' ? 'Nessun file' : 'No file'}</span>
            </div>
          </div>
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-1">{lang === 'es' ? 'Extracto Profesional' : lang === 'it' ? 'Profilo Professionale' : 'Professional Summary'}</label>
            <textarea data-path="basics.summary" rows="4" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm focus:outline-blue-500"></textarea>
          </div>
        </div>

        <div id="tab-work" class="tab-content space-y-4 hidden">
          <div id="work-container" class="space-y-4"></div>
          <button type="button" id="btn-add-work" class="w-full py-2 bg-blue-50 hover:bg-blue-100 text-blue-600 text-xs font-semibold rounded-xl border border-dashed border-blue-200">
            {lang === 'es' ? '+ Añadir Experiencia' : lang === 'it' ? '+ Aggiungi Esperienza' : '+ Add Experience'}
          </button>
        </div>

        <div id="tab-education" class="tab-content space-y-4 hidden">
          <div id="education-container" class="space-y-4"></div>
          <button type="button" id="btn-add-edu" class="w-full py-2 bg-blue-50 hover:bg-blue-100 text-blue-600 text-xs font-semibold rounded-xl border border-dashed border-blue-200">
            {lang === 'es' ? '+ Añadir Formación' : lang === 'it' ? '+ Aggiungi Formazione' : '+ Add Education'}
          </button>
        </div>

        <div id="tab-extras" class="tab-content space-y-6 hidden">
          <div>
            <div class="flex items-center justify-between border-b border-gray-100 pb-3 mb-3">
              <h2 class="text-sm font-bold text-gray-900">{lang === 'es' ? 'Certificados y titulaciones' : lang === 'it' ? 'Certificati e titoli' : 'Certificates & Degrees'}</h2>
            </div>
            <div id="certificates-container" class="space-y-4"></div>
            <button type="button" id="btn-add-certificate" class="w-full py-2 bg-blue-50 hover:bg-blue-100 text-blue-600 text-xs font-semibold rounded-xl border border-dashed border-blue-200">
              {lang === 'es' ? '+ Añadir Certificado' : lang === 'it' ? '+ Aggiungi Certificato' : '+ Add Certificate'}
            </button>
          </div>

          <div>
            <div class="flex items-center justify-between border-b border-gray-100 pb-3 mb-3">
              <h2 class="text-sm font-bold text-gray-900">{lang === 'es' ? 'Idiomas' : lang === 'it' ? 'Lingue' : 'Languages'}</h2>
            </div>
            <div id="languages-container" class="space-y-4"></div>
            <button type="button" id="btn-add-language" class="w-full py-2 bg-blue-50 hover:bg-blue-100 text-blue-600 text-xs font-semibold rounded-xl border border-dashed border-blue-200">
              {lang === 'es' ? '+ Añadir Idioma' : lang === 'it' ? '+ Aggiungi Lingua' : '+ Add Language'}
            </button>
          </div>
        </div>

        <div id="tab-skills" class="tab-content space-y-4 hidden">
          <div class="hidden sm:block bg-blue-50/60 p-3.5 rounded-xl border border-blue-100 text-xs text-blue-800">
            💡 <strong>{lang === 'es' ? 'Instrucciones:' : lang === 'it' ? 'Istruzioni:' : 'Instructions:'}</strong> {lang === 'es' ? 'Escribe una habilidad y pulsa Enter o coma (,).' : lang === 'it' ? 'Scrivi una competenza e premi Invio o virgola (,).' : 'Type a skill and press Enter or comma (,).'}
          </div>
          <div>
            <input type="text" id="skills-input" placeholder="Ej: JavaScript..." class="w-full px-3 py-2 border border-gray-200 rounded-lg text-sm outline-none" />
          </div>
          <div id="skills-tag-container" class="flex flex-wrap gap-1.5 p-3 border border-gray-200 rounded-xl bg-gray-50/50 min-h-[60px]"></div>
        </div>

        <div id="tab-templates" class="tab-content hidden">
            <label class="block text-xs font-semibold text-gray-500 uppercase mb-3">
              {t('templates.subtitle') || (lang === 'es' ? 'Elige el aspecto visual de tu CV' : lang === 'it' ? "Scegli l'aspetto visivo del tuo CV" : 'Choose the visual style of your resume')}
            </label>
            
            {/* Agregamos sm:grid-cols-3 para que si en pantallas grandes hay 3 plantillas, se vean alineadas */}
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {templates.map((tpl, i) => {
            // 1. Calculamos la clave de traducción
            const key = `templates.${tpl.id}` as UIKeys;
            const translated = t(key);
            
            // 2. Determinamos qué mostrar: si la traducción es igual a la clave, usamos el displayName, si no, la traducción
            const displayName = translated !== key ? translated : tpl.displayName;

            return (
              <div 
                data-template-id={tpl.id} 
                class={`template-card border-2 p-3 rounded-xl bg-white shadow-sm cursor-pointer hover:border-blue-300 transition-all group relative ${i === 0 ? 'border-blue-600 ring-2 ring-blue-100' : 'border-gray-200'}`}
              >
                <div class="aspect-[4/5] w-full bg-gray-50 rounded-lg p-2 mb-2 border border-gray-100 group-hover:scale-[1.02] transition-transform">
                  <Fragment set:html={tpl.svg} />
                </div>
                
                {/* Aquí ya no usamos name, usamos displayName y la lógica de traducción corregida */}
                <div class="text-sm font-bold text-gray-900 text-center group-hover:text-blue-600 truncate tracking-wide mt-1.5">
                  {displayName}
                </div>
              </div>
            );
          })}
        </div>
      </div>

      </div>
    </div>

    <div
      id="preview-section"
      class="hidden xl:block bg-white p-8 rounded-2xl border border-gray-200 shadow-lg xl:min-h-[297mm] print:block print:shadow-none print:border-0 print:p-0"
    >
      
      <header id="preview-header" class="flex justify-between items-start pb-6 border-b border-gray-100">
        <div class="flex-1">
          <h2 id="view-name" class="text-3xl font-bold tracking-tight text-gray-900"></h2>
          <p id="view-label" class="mt-1 text-base text-gray-600 font-medium"></p>
          <div id="view-contact" class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-gray-500"></div>
        </div>
        <img id="view-image" class="w-24 h-24 rounded-xl object-cover border border-gray-200 hidden" alt="Foto" />
      </header>
      
      <section id="section-summary" class="mt-6">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2 pb-1 border-b border-gray-100">
          {lang === 'es' ? 'Perfil' : lang === 'it' ? 'Profilo' : 'Profile'}
        </h3>
        <p id="view-summary" class="text-sm text-gray-600 leading-relaxed whitespace-pre-line"></p>
      </section>
      
      <section id="section-experience" class="mt-6">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3 pb-1 border-b border-gray-100">
          {lang === 'es' ? 'Experiencia' : lang === 'it' ? 'Esperienza' : 'Experience'}
        </h3>
        <div id="view-experience" class="space-y-4"></div>
      </section>
      
      <section id="section-education" class="mt-6">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3 pb-1 border-b border-gray-100">
          {lang === 'es' ? 'Formación' : lang === 'it' ? 'Formazione' : 'Education'}
        </h3>
        <div id="view-education" class="space-y-4"></div>
      </section>
      
      <section id="section-certificates" class="mt-6">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3 pb-1 border-b border-gray-100">
          {lang === 'es' ? 'Certificados' : lang === 'it' ? 'Certificati' : 'Certificates'}
        </h3>
        <div id="view-certificates" class="space-y-4"></div>
      </section>

      <section id="section-languages" class="mt-6">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3 pb-1 border-b border-gray-100">
          {lang === 'es' ? 'Idiomas' : lang === 'it' ? 'Lingue' : 'Languages'}
        </h3>
        <div id="view-languages" class="space-y-2"></div>
      </section>
      
      <section id="section-skills" class="mt-6">
        <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2 pb-1 border-b border-gray-100">
          {lang === 'es' ? 'Habilidades' : lang === 'it' ? 'Competenze' : 'Skills'}
        </h3>
        <div id="view-skills-badges" class="flex flex-wrap gap-1.5"></div>
      </section>
    </div>

  </div>

  <div class="print:hidden p-4 sm:p-6 border-t border-gray-200 bg-white">
    <button id="btn-publish" class="w-full sm:w-auto px-5 py-3 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-xl transition-all">{t('edit.publish')}</button>
  </div>

  <style is:global>
    #preview-section { font-family: 'Inter', system-ui, sans-serif; color: #111827; }
    .badge-item-live { background-color: #f3f4f6; color: #374151; font-size: 0.75rem; padding: 0.25rem 0.625rem; border-radius: 9999px; display: inline-block; font-weight: 500; }
    /* Hide horizontal scrollbar on the tabs nav for all screen sizes */
    #tab-nav { -ms-overflow-style: none; scrollbar-width: none; }
    #tab-nav::-webkit-scrollbar { display: none; height: 0; }
    /* Active tab underline style (ensure visible on all sizes) */
    .tab-btn { border-bottom-width: 2px; }
    .tab-btn.border-blue-600 { border-bottom-color: #2563eb; }

    /* ===== LAYOUT: MINIMALIST ===== */
    [data-template="minimalist"] #preview-header {
      display: flex !important;
      align-items: start !important;
      justify-content: flex-start !important;
      gap: 1.5rem !important;
    }
    [data-template="minimalist"] #preview-header img {
      order: -1 !important;
    }

    /* ===== LAYOUT: TECHY ===== */
    [data-template="techy"] {
      background-color: #f1f5f9 !important;
      background-image: radial-gradient(#cbd5e1 1px, transparent 1px) !important;
      background-size: 16px 16px !important;
      color: #0f172a !important;
    }
    [data-template="techy"] #preview-header {
      display: flex !important;
      align-items: start !important;
      justify-content: flex-start !important;
      gap: 1.5rem !important;
    }
    [data-template="techy"] #preview-header img {
      order: -1 !important;
      border-radius: 8px !important;
      border: 2px solid #6366f1 !important;
    }
    [data-template="techy"] #view-name {
      font-family: 'JetBrains Mono', monospace !important;
      color: #1e1b4b !important;
      font-weight: 700 !important;
    }
    [data-template="techy"] h3::before {
      content: "</> " !important;
      color: #6366f1 !important;
      font-family: 'JetBrains Mono', monospace !important;
    }
    [data-template="techy"] h3 {
      font-family: 'JetBrains Mono', monospace !important;
      color: #4338ca !important;
      border-bottom: 1px dashed #cbd5e1 !important;
    }
    [data-template="techy"] .badge-item-live {
      background-color: #e0e7ff !important;
      color: #4338ca !important;
      border: 1px solid #c7d2fe !important;
      font-family: 'JetBrains Mono', monospace !important;
      border-radius: 4px !important;
      font-size: 0.7rem !important;
    }

    /* ===== LAYOUT: ARTISTIC ===== */
    [data-template="artistic"] {
      background-color: #faf6f0 !important;
      color: #443e38 !important;
    }
    [data-template="artistic"] #preview-header {
      display: flex !important;
      align-items: start !important;
      justify-content: flex-start !important;
      gap: 1.75rem !important;
    }
    [data-template="artistic"] #preview-header img {
      order: -1 !important;
      border-radius: 60% 40% 60% 40% / 40% 60% 40% 60% !important;
      border: 2px solid #8c7864 !important;
      padding: 3px !important;
      background-color: #ffffff;
    }
    [data-template="artistic"] #view-name {
      font-family: 'Playfair Display', Georgia, serif !important;
      color: #2e2924 !important;
      font-size: 2.1rem !important;
      font-style: italic !important;
    }
    [data-template="artistic"] h3 {
      font-family: 'Playfair Display', Georgia, serif !important;
      color: #8c7864 !important;
      font-size: 1rem !important;
      letter-spacing: 0.025em !important;
      border-bottom: 1px solid #e3dac9 !important;
    }
    [data-template="artistic"] .badge-item-live {
      background-color: #f1eae1 !important;
      color: #6e5d4f !important;
      border: 1px solid #e3dac9 !important;
      border-radius: 9999px !important;
      font-style: italic !important;
      font-size: 0.75rem !important;
    }

    /* Print adjustments to avoid extra blank pages */
    @media print {
      #preview-section { min-height: auto !important; box-shadow: none !important; border: 0 !important; }
      @page { size: A4; margin: 10mm; }
      html, body { height: auto !important; }
      .print\:block { display: block !important; }
    }
  </style>

  <script define:vars={{ lang, initialData, currentTranslation: t('edit.currently') }}>
    const STORAGE_KEY = `cv_backup_data_${lang}`;
    const TEMPLATE_KEY = `cv_selected_template_${lang}`;

    // Diccionario de textos de sustitución limpios según el idioma del cliente
    const translationsUI = {
      es: { defaultName: "Tu Nombre", defaultLabel: "Tu Profesión u Oficio" },
      it: { defaultName: "Il Tuo Nome", defaultLabel: "La Tua Professione" },
      en: { defaultName: "Your Name", defaultLabel: "Your Profession" }
    }[lang] || { defaultName: "Tu Nombre", defaultLabel: "Tu Profesión" };

    // Función para cargar datos del servidor (si está autenticado)
    async function loadRemoteResume() {
      try {
        const response = await fetch(`/.netlify/functions/load-resume?lang=${lang}`, {
          method: 'GET',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' }
        });

        if (!response.ok) return null;

        const result = await response.json();
        
        if (result.authenticated && result.data) {
          // Guardar en localStorage y retornar
          localStorage.setItem(STORAGE_KEY, JSON.stringify(result.data));
          return result.data;
        }
      } catch (err) {
        console.error('Error cargando resume remoto:', err);
      }
      return null;
    }

    let state = (() => {
      try {
        const saved = localStorage.getItem(STORAGE_KEY);
        return saved ? JSON.parse(saved) : initialData;
      } catch {
        return initialData;
      }
    })();

    if (!state.basics) state.basics = { name: "", label: "", email: "", phone: "", summary: "", image: "" };
    if (!state.work) state.work = [];
    if (!state.education) state.education = [];
    if (!state.certificates) state.certificates = [];
    if (!state.languages) state.languages = [];
    if (!state.meta) state.meta = {};
    if (!state.skills) state.skills = [];

    function normalizeMonthValue(value) {
      if (!value) return '';
      return value.slice(0, 7);
    }

    function normalizeStateDates() {
      const normalizeDates = (item) => {
        ['startDate', 'endDate'].forEach((key) => {
          if (item[key]) item[key] = normalizeMonthValue(item[key]);
        });
      };
      state.work.forEach(normalizeDates);
      state.education.forEach(normalizeDates);
      state.certificates.forEach((item) => {
        if (item.date) item.date = normalizeMonthValue(item.date);
      });
    }

    function formatDateRange(start, end) {
      const from = normalizeMonthValue(start);
      const to = end ? normalizeMonthValue(end) : currentTranslation;
      if (from && to) return `${from} — ${to}`;
      return to || from || '';
    }

    normalizeStateDates();

    const labels = {
      es: { company: 'Empresa', position: 'Puesto', start: 'Inicio', end: 'Fin', desc: 'Descripción', inst: 'Institución', area: 'Titulación', remove: 'Eliminar' },
      it: { company: 'Azienda', position: 'Ruolo', start: 'Inizio', end: 'Fine', desc: 'Descrizione', inst: 'Istituto', area: 'Titolo', remove: 'Elimina' },
      en: { company: 'Company', position: 'Position', start: 'Start Date', end: 'End Date', desc: 'Description', inst: 'Institution', area: 'Area of Study', remove: 'Remove' }
    }[lang];

    function setDeepValue(obj, path, value) {
      const parts = path.split('.');
      let current = obj;
      for (let i = 0; i < parts.length - 1; i++) {
        const key = parts[i];
        if (!(key in current)) current[key] = isNaN(parts[i + 1]) ? {} : [];
        current = current[key];
      }
      current[parts[parts.length - 1]] = value;
    }

    function getDeepValue(obj, path) {
      return path.split('.').reduce((acc, part) => acc && acc[part], obj);
    }

    function saveState() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      renderPreview();
    }

    function applyTemplate(templateId) {
  // 1. Resaltar visualmente la tarjeta seleccionada en el formulario
  document.querySelectorAll('.template-card').forEach(c => {
    if (c.dataset.templateId === templateId.toLowerCase()) {
      c.classList.remove('border-gray-200');
      c.classList.add('border-blue-600', 'ring-2', 'ring-blue-100');
    } else {
      c.classList.remove('border-blue-600', 'ring-2', 'ring-blue-100');
      c.classList.add('border-gray-200');
    }
  });

  // 2. Guardar la selección en el estado local
  state.meta.template = templateId;
  localStorage.setItem(TEMPLATE_KEY, templateId);

  // 💥 EL DISPARADOR MÁGICO: Cambiamos el atributo data-template de la preview
  // Esto activará instantáneamente los estilos globales del Layout cargado sin tocar el formulario
  const preview = document.getElementById('preview-section');
  if (preview) {
    preview.setAttribute('data-template', templateId.toLowerCase());
  }
}

    document.querySelectorAll('.template-card').forEach(card => {
      card.addEventListener('click', () => { applyTemplate(card.dataset.templateId); saveState(); });
    });

    const fileInput = document.getElementById('photo-file');
    const photoStatus = document.getElementById('photo-status');
    const removePhotoBtn = document.getElementById('btn-remove-photo');

    fileInput?.addEventListener('change', (e) => {
      const file = e.target.files?.[0];
      if (!file) return;
      if (photoStatus) photoStatus.textContent = file.name;
      removePhotoBtn?.classList.remove('hidden');
      const reader = new FileReader();
      reader.onload = (event) => {
        if (event.target?.result) {
          state.basics.image = event.target.result;
          saveState();
        }
      };
      reader.readAsDataURL(file);
    });

    removePhotoBtn?.addEventListener('click', () => {
      state.basics.image = "";
      if (fileInput) fileInput.value = "";
      if (photoStatus) photoStatus.textContent = lang === 'es' ? 'Sin archivo' : lang === 'it' ? 'Nessun file' : 'No file';
      removePhotoBtn.classList.add('hidden');
      saveState();
    });

    const tabButtons = Array.from(document.querySelectorAll('.tab-btn'));
    const tabNav = document.getElementById('tab-nav');
    const tabPrev = document.getElementById('tab-prev');
    const tabNext = document.getElementById('tab-next');

    function activateTab(btn) {
      document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('border-blue-600', 'text-blue-600');
        b.classList.add('border-transparent', 'text-gray-500');
      });
      btn.classList.add('border-blue-600', 'text-blue-600');
      document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
      document.getElementById(`tab-${btn.dataset.tab}`)?.classList.remove('hidden');
      btn.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
    }

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => activateTab(btn));
    });

    function getActiveTabIndex() {
      return tabButtons.findIndex(btn => btn.classList.contains('border-blue-600'));
    }

    tabPrev?.addEventListener('click', () => {
      const currentIndex = getActiveTabIndex();
      const prevIndex = currentIndex <= 0 ? tabButtons.length - 1 : currentIndex - 1;
      activateTab(tabButtons[prevIndex]);
    });

    tabNext?.addEventListener('click', () => {
      const currentIndex = getActiveTabIndex();
      const nextIndex = currentIndex === -1 || currentIndex === tabButtons.length - 1 ? 0 : currentIndex + 1;
      activateTab(tabButtons[nextIndex]);
    });

    tabPrev?.addEventListener('touchstart', () => tabNav?.scrollBy({ left: -150, behavior: 'smooth' }));
    tabNext?.addEventListener('touchstart', () => tabNav?.scrollBy({ left: 150, behavior: 'smooth' }));

    function setupInputSync() {
      document.querySelectorAll('#cv-form input[data-path], #cv-form textarea[data-path]').forEach(input => {
        input.replaceWith(input.cloneNode(true));
      });
      document.querySelectorAll('#cv-form input[data-path], #cv-form textarea[data-path]').forEach(input => {
        input.addEventListener('input', (e) => {
          const path = e.target.getAttribute('data-path');
          if (path) {
            setDeepValue(state, path, e.target.value);
            saveState();
          }
        });
      });
    }

    function populateFormBasics() {
      document.querySelectorAll('#cv-form input[data-path], #cv-form textarea[data-path]').forEach(input => {
        const path = input.getAttribute('data-path');
        if (path) input.value = getDeepValue(state, path) || "";
      });
      if (state.basics.image && photoStatus) {
        photoStatus.textContent = lang === 'es' ? 'Imagen cargada' : lang === 'it' ? 'Immagine caricata' : 'Image loaded';
        removePhotoBtn?.classList.remove('hidden');
      }
    }

    function renderDynamicBlocks() {
      const workContainer = document.getElementById('work-container');
      if (workContainer) {
        workContainer.innerHTML = '';
        state.work.forEach((item, index) => { workContainer.appendChild(createWorkBlock(item, index)); });
      }
      const eduContainer = document.getElementById('education-container');
      if (eduContainer) {
        eduContainer.innerHTML = '';
        state.education.forEach((item, index) => { eduContainer.appendChild(createEduBlock(item, index)); });
      }
      const certContainer = document.getElementById('certificates-container');
      if (certContainer) {
        certContainer.innerHTML = '';
        state.certificates.forEach((item, index) => { certContainer.appendChild(createCertificateBlock(item, index)); });
      }
      const langContainer = document.getElementById('languages-container');
      if (langContainer) {
        langContainer.innerHTML = '';
        state.languages.forEach((item, index) => { langContainer.appendChild(createLanguageBlock(item, index)); });
      }
      setupInputSync();
    }

    function createWorkBlock(item, index) {
      const div = document.createElement('div');
      div.className = "p-4 bg-gray-50 rounded-xl border border-gray-200 relative space-y-3";
      div.innerHTML = `
        <button type="button" class="absolute top-2 right-2 text-red-500 text-xs font-medium" onclick="removeWorkBlock(${index})">${labels.remove}</button>
        <div class="grid sm:grid-cols-2 gap-3 pt-3">
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${labels.company}</label>
            <input type="text" data-path="work.${index}.name" value="${item.name || ''}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${labels.position}</label>
            <input type="text" data-path="work.${index}.position" value="${item.position || ''}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${labels.start}</label>
            <input type="month" data-path="work.${index}.startDate" value="${normalizeMonthValue(item.startDate || '')}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${labels.end}</label>
            <input type="month" data-path="work.${index}.endDate" value="${normalizeMonthValue(item.endDate || '')}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
        </div>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${labels.desc}</label>
          <textarea data-path="work.${index}.summary" rows="2" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm">${item.summary || ''}</textarea>
        </div>
      `;
      return div;
    }

    window.removeWorkBlock = (index) => { state.work.splice(index, 1); saveState(); renderDynamicBlocks(); };

    function createEduBlock(item, index) {
      const div = document.createElement('div');
      div.className = "p-4 bg-gray-50 rounded-xl border border-gray-200 relative space-y-3";
      div.innerHTML = `
        <button type="button" class="absolute top-2 right-2 text-red-500 text-xs font-medium" onclick="removeEduBlock(${index})">${labels.remove}</button>
        <div class="grid sm:grid-cols-2 gap-3 pt-3">
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${labels.inst}</label>
            <input type="text" data-path="education.${index}.institution" value="${item.institution || ''}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${labels.area}</label>
            <input type="text" data-path="education.${index}.area" value="${item.area || ''}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${labels.start}</label>
            <input type="month" data-path="education.${index}.startDate" value="${normalizeMonthValue(item.startDate || '')}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${labels.end}</label>
            <input type="month" data-path="education.${index}.endDate" value="${normalizeMonthValue(item.endDate || '')}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
        </div>
      `;
      return div;
    }

    window.removeEduBlock = (index) => { state.education.splice(index, 1); saveState(); renderDynamicBlocks(); };

    function createCertificateBlock(item, index) {
      const div = document.createElement('div');
      div.className = "p-4 bg-gray-50 rounded-xl border border-gray-200 relative space-y-3";
      div.innerHTML = `
        <button type="button" class="absolute top-2 right-2 text-red-500 text-xs font-medium" onclick="removeCertificateBlock(${index})">${labels.remove}</button>
        <div>
          <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${lang === 'es' ? 'Nombre del certificado' : lang === 'it' ? 'Nome certificato' : 'Certificate name'}</label>
          <input type="text" data-path="certificates.${index}.name" value="${item.name || ''}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
        </div>
        <div class="grid sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${lang === 'es' ? 'Emisor' : lang === 'it' ? 'Emittente' : 'Issuer'}</label>
            <input type="text" data-path="certificates.${index}.issuer" value="${item.issuer || ''}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${lang === 'es' ? 'Fecha' : lang === 'it' ? 'Data' : 'Date'}</label>
            <input type="month" data-path="certificates.${index}.date" value="${normalizeMonthValue(item.date || '')}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
        </div>
      `;
      return div;
    }

    window.removeCertificateBlock = (index) => { state.certificates.splice(index, 1); saveState(); renderDynamicBlocks(); };

    function createLanguageBlock(item, index) {
      const div = document.createElement('div');
      div.className = "p-4 bg-gray-50 rounded-xl border border-gray-200 relative space-y-3";
      div.innerHTML = `
        <button type="button" class="absolute top-2 right-2 text-red-500 text-xs font-medium" onclick="removeLanguageBlock(${index})">${labels.remove}</button>
        <div class="grid sm:grid-cols-2 gap-3">
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${lang === 'es' ? 'Idioma' : lang === 'it' ? 'Lingua' : 'Language'}</label>
            <input type="text" data-path="languages.${index}.language" value="${item.language || ''}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase mb-0.5">${lang === 'es' ? 'Nivel' : lang === 'it' ? 'Livello' : 'Fluency'}</label>
            <input type="text" data-path="languages.${index}.fluency" value="${item.fluency || ''}" class="w-full px-2.5 py-1.5 border border-gray-200 rounded-lg text-sm" />
          </div>
        </div>
      `;
      return div;
    }

    window.removeLanguageBlock = (index) => { state.languages.splice(index, 1); saveState(); renderDynamicBlocks(); };

    document.getElementById('btn-add-work')?.addEventListener('click', () => {
      state.work.push({ name: "", position: "", startDate: "", endDate: "", summary: "" });
      saveState(); renderDynamicBlocks();
    });

    document.getElementById('btn-add-edu')?.addEventListener('click', () => {
      state.education.push({ institution: "", area: "", startDate: "", endDate: "" });
      saveState(); renderDynamicBlocks();
    });

    document.getElementById('btn-add-certificate')?.addEventListener('click', () => {
      state.certificates.push({ name: "", issuer: "", date: "" });
      saveState(); renderDynamicBlocks();
    });

    document.getElementById('btn-add-language')?.addEventListener('click', () => {
      state.languages.push({ language: "", fluency: "" });
      saveState(); renderDynamicBlocks();
    });

    const skillsInput = document.getElementById('skills-input');
    const skillsTagContainer = document.getElementById('skills-tag-container');

    function renderSkillsTags() {
      if (!skillsTagContainer) return;
      document.querySelectorAll('.skill-tag-item').forEach(el => el.remove());
      state.skills.forEach((skillObj, idx) => {
        if (!skillObj.name) return;
        const div = document.createElement('div');
        div.className = "skill-tag-item inline-flex items-center gap-1.5 bg-blue-600 text-white text-xs font-bold px-2.5 py-1 rounded-lg";
        div.innerHTML = `<span>${skillObj.name}</span><button type="button" class="text-blue-200 hover:text-white font-extrabold ml-0.5" onclick="removeSkillObj(${idx})">&times;</button>`;
        skillsTagContainer.appendChild(div);
      });
      renderPreview();
    }

    window.removeSkillObj = (idx) => { state.skills.splice(idx, 1); saveState(); renderSkillsTags(); };

    skillsInput?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        let val = skillsInput.value.replace(/,/g, '').trim();
        if (val) {
          if (!state.skills.some(s => s.name.toLowerCase() === val.toLowerCase())) {
            state.skills.push({ name: val });
            saveState(); renderSkillsTags();
          }
        }
        skillsInput.value = '';
      }
    });

    function toggleSection(id, hasContent) {
      const el = document.getElementById(id);
      if (el) el.classList.toggle('hidden', !hasContent);
    }

    function renderPreview() {
      const nameEl = document.getElementById('view-name');
      const labelEl = document.getElementById('view-label');
      const summaryEl = document.getElementById('view-summary');
      const contactEl = document.getElementById('view-contact');

      if (nameEl) nameEl.textContent = state.basics.name.trim() || translationsUI.defaultName;
      if (labelEl) labelEl.textContent = state.basics.label.trim() || translationsUI.defaultLabel;
      if (summaryEl) summaryEl.textContent = state.basics.summary || '';
      toggleSection('section-summary', !!state.basics.summary);

      if (contactEl) {
        let html = '';
        if (state.basics.email) html += `<span>📧 ${state.basics.email}</span>`;
        if (state.basics.phone) html += `<span>📞 ${state.basics.phone}</span>`;
        const website = state.basics.web || state.basics.url || '';
      if (website) html += `<span>🔗 <a href="${website}" target="_blank" rel="noopener noreferrer">${website}</a></span>`;
        contactEl.innerHTML = html;
      }

      const imgEl = document.getElementById('view-image');
      if (imgEl) {
        if (state.basics.image) {
          imgEl.src = state.basics.image;
          imgEl.classList.remove('hidden');
        } else {
          imgEl.classList.add('hidden');
        }
      }

      const expEl = document.getElementById('view-experience');
      if (expEl) {
        expEl.innerHTML = '';
        state.work.forEach(w => {
          const div = document.createElement('div');
          div.innerHTML = `
            <div class="flex justify-between font-semibold text-sm">
              <span class="text-gray-900 font-bold">${w.position || ''}</span>
              <span class="text-gray-500 text-xs">${formatDateRange(w.startDate, w.endDate)}</span>
            </div>
            <div class="text-blue-600 text-xs font-medium">${w.name || ''}</div>
            <p class="text-gray-600 text-xs mt-1 whitespace-pre-line">${w.summary || ''}</p>
          `;
          expEl.appendChild(div);
        });
        toggleSection('section-experience', state.work.length > 0);
      }

      const eduEl = document.getElementById('view-education');
      if (eduEl) {
        eduEl.innerHTML = '';
        state.education.forEach(e => {
          const div = document.createElement('div');
          div.innerHTML = `
            <div class="flex justify-between font-semibold text-sm">
              <span class="text-gray-900 font-bold">${e.area || ''}</span>
              <span class="text-gray-500 text-xs">${formatDateRange(e.startDate, e.endDate)}</span>
            </div>
            <div class="text-gray-500 text-xs font-medium">${e.institution || ''}</div>
          `;
          eduEl.appendChild(div);
        });
        toggleSection('section-education', state.education.length > 0);
      }

      const certEl = document.getElementById('view-certificates');
      if (certEl) {
        certEl.innerHTML = '';
        state.certificates.forEach(c => {
          const div = document.createElement('div');
          div.innerHTML = `
            <div class="flex justify-between font-semibold text-sm">
              <span class="text-gray-900 font-bold">${c.name || ''}</span>
              <span class="text-gray-500 text-xs">${normalizeMonthValue(c.date || '')}</span>
            </div>
            <div class="text-gray-500 text-xs font-medium">${c.issuer || ''}</div>
          `;
          certEl.appendChild(div);
        });
        toggleSection('section-certificates', state.certificates.length > 0);
      }

      const langEl = document.getElementById('view-languages');
      if (langEl) {
        langEl.innerHTML = '';
        state.languages.forEach(l => {
          const div = document.createElement('div');
          div.className = "flex justify-between text-sm text-gray-700";
          div.innerHTML = `<span>${l.language || ''}</span><span class="text-gray-500">${l.fluency || ''}</span>`;
          langEl.appendChild(div);
        });
        toggleSection('section-languages', state.languages.length > 0);
      }

      const badgesEl = document.getElementById('view-skills-badges');
      if (badgesEl) {
        badgesEl.innerHTML = '';
        state.skills.forEach(s => {
          if (!s.name) return;
          const span = document.createElement('span');
          span.className = "badge-item-live border shadow-xs";
          span.textContent = s.name;
          badgesEl.appendChild(span);
        });
        toggleSection('section-skills', state.skills.length > 0);
      }
    }

    document.querySelectorAll('.btn-print-control').forEach(btn => {
      btn.addEventListener('click', () => {
        window.print();
      });
    });

    document.querySelectorAll('.btn-download-json-control').forEach(btn => {
      btn.addEventListener('click', () => {
        const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(state, null, 2));
        const anchor = document.createElement('a');
        anchor.setAttribute("href", dataStr);
        anchor.setAttribute("download", `resume.${lang}.json`);
        document.body.appendChild(anchor);
        anchor.click(); anchor.remove();
      });
    });

    document.getElementById('btn-publish')?.addEventListener('click', async () => {
      const btn = document.getElementById('btn-publish');
      if (!btn) return;
      
      // Verificar si está autenticado (cookie github_user disponible)
      const isAuthenticated = document.cookie.includes('github_user=');
      
      if (!isAuthenticated) {
        const confirmLogin = confirm(
          lang === 'es' 
            ? '¿Conectar tu GitHub para publicar tu CV en tu propia web?'
            : lang === 'it'
            ? 'Vuoi collegare il tuo GitHub per pubblicare il tuo CV sul tuo sito web?'
            : 'Do you want to connect your GitHub to publish your CV on your own website?'
        );
        
        if (confirmLogin) {
          window.location.href = '/.netlify/functions/auth-login';
        }
        return;
      }
      
      btn.disabled = true;
      const originalText = btn.textContent;
      btn.textContent = lang === 'es' ? 'Publicando...' : lang === 'it' ? 'Pubblicazione...' : 'Publishing...';
      
      try {
        const savedLangs = ['es', 'it', 'en'];
        const resumeDataByLang = {};

        savedLangs.forEach((code) => {
          const saved = localStorage.getItem(`cv_backup_data_${code}`);
          if (!saved) return;
          try {
            const parsed = JSON.parse(saved);
            if (parsed?.basics?.name?.trim()) {
              resumeDataByLang[code] = parsed;
            }
          } catch {
            // ignorar entradas corruptas
          }
        });

        if (!resumeDataByLang[lang]) {
          resumeDataByLang[lang] = state;
        }

        const response = await fetch('/.netlify/functions/deploy', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            langs: Object.keys(resumeDataByLang),
            resumeDataByLang,
            template: state.meta?.template || localStorage.getItem(TEMPLATE_KEY) || 'minimalist'
          })
        });

        const data = await response.json();

        if (response.ok) {
          const successMsg = lang === 'es'
            ? `¡Publicado! Tu CV está en: ${data.webUrl}`
            : lang === 'it'
            ? `Pubblicato! Il tuo CV è su: ${data.webUrl}`
            : `Published! Your CV is at: ${data.webUrl}`;
          alert(successMsg);
        } else {
          alert(data.error || (lang === 'es' ? 'Error al publicar.' : lang === 'it' ? 'Errore nella pubblicazione.' : 'Error publishing.'));
        }
      } catch (err) {
        console.error('Error:', err);
        alert(lang === 'es' ? 'Error de conexión.' : lang === 'it' ? 'Errore di connessione.' : 'Connection error.');
      } finally {
        btn.disabled = false;
        btn.textContent = originalText;
      }
    });

    const savedTemplate = state.meta?.template || localStorage.getItem(TEMPLATE_KEY) || 'minimalist';
    
    // Configurar botón de autenticación de GitHub
    const githubBtns = Array.from(document.querySelectorAll('.btn-github-auth-control'));
    const statusTexts = Array.from(document.querySelectorAll('.github-status-text'));
    
    function updateGitHubAuthStatus() {
      const isAuthenticated = document.cookie.includes('github_user=');
      const username = document.cookie.split('github_user=')[1]?.split(';')[0] || '';
      githubBtns.forEach(btn => {
        if (isAuthenticated) {
          btn.classList.remove('bg-gray-800', 'hover:bg-gray-900');
          btn.classList.add('bg-green-600', 'hover:bg-green-700');
        } else {
          btn.classList.remove('bg-green-600', 'hover:bg-green-700');
          btn.classList.add('bg-gray-800', 'hover:bg-gray-900');
        }
      });
      statusTexts.forEach(el => {
        el.textContent = isAuthenticated ? `✓ ${username}` : (lang === 'es' ? 'Conectar' : lang === 'it' ? 'Collegare' : 'Connect');
      });
    }
    
    githubBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const isAuthenticated = document.cookie.includes('github_user=');
        if (isAuthenticated) {
          const logout = confirm(lang === 'es' ? '¿Desconectar de GitHub?' : lang === 'it' ? 'Disconnettere da GitHub?' : 'Disconnect from GitHub?');
          if (logout) {
            document.cookie = 'github_token=; Max-Age=0; Path=/';
            document.cookie = 'github_user=; Max-Age=0; Path=/';
            updateGitHubAuthStatus();
          }
        } else {
          window.location.href = '/.netlify/functions/auth-login';
        }
      });
    });
    
    updateGitHubAuthStatus();
    (async () => {
      const remoteData = await loadRemoteResume();
      if (remoteData) {
        state = remoteData;
      }
      populateFormBasics();
      renderDynamicBlocks();
      renderSkillsTags();
      applyTemplate(savedTemplate);
    })();
  </script>

  <!-- Cookie Consent Banner -->
  <div id="privacy-banner"
    class="fixed bottom-4 left-4 right-4 md:left-4 md:right-auto md:max-w-md bg-white border border-gray-200 p-4 rounded-xl shadow-2xl z-50 opacity-0 translate-y-8 pointer-events-none flex flex-col sm:flex-row items-start sm:items-center gap-4 transition-all duration-500 ease-out"
  >
    <div class="hidden sm:flex flex-shrink-0 w-16 h-16 overflow-hidden items-end self-end -mb-4">
      <img src="https://media1.giphy.com/media/v1.Y2lkPTc5MGI3NjExbG5uaXVwc3ZvY3A0Z2Nvenk0YWZqcWV4amtydHIyOHp4eHNrd2N4ZiZlcD12MV9pbnRlcm5hbF9naWZfYnlfaWQmY3Q9cw/CPsnRKLWN0XS9DO4Ej/giphy.gif"
        alt="Cookie consent" class="w-full h-auto object-contain max-h-[110%] origin-bottom scale-110" loading="lazy" />
    </div>
    <div class="flex-1 flex flex-col gap-3">
      <div>
        <h4 class="text-sm font-bold text-gray-900 mb-1">
          {lang === 'it' ? 'Uso dei Cookie' : 'Uso de Cookies'}
        </h4>
        <p class="text-xs text-gray-500 leading-relaxed m-0 text-left">
          {lang === 'it'
            ? 'Utilizziamo cookie propri e di terze parti per analizzare le prestazioni del sito e migliorare la tua esperienza. Puoi accettare tutti i cookie o rifiutarli.'
            : 'Utilizamos cookies propias y de terceros para analizar el rendimiento de la web y mejorar tu experiencia. Puedes aceptar todas las cookies o rechazarlas.'}
          <a href="https://raulmguerrero.com/terms" target="_blank" rel="noopener"
            class="text-blue-600 font-bold underline hover:opacity-80 transition-opacity">
            {lang === 'it' ? 'termini di utilizzo' : 'términos de uso'}
          </a>
          {lang === 'it' ? ' e ' : ' y '}
          <a href="https://raulmguerrero.com/privacy" target="_blank" rel="noopener"
            class="text-blue-600 font-bold underline hover:opacity-80 transition-opacity">
            {lang === 'it' ? 'informativa sulla privacy' : 'política de privacidad'}
          </a>.
        </p>
      </div>
      <div class="flex items-center gap-2 self-end sm:self-start w-full sm:w-auto">
        <button id="accept-privacy"
          class="flex-1 sm:flex-initial text-center cursor-pointer bg-blue-600 text-white text-xs font-semibold py-2 px-4 rounded-lg shadow-sm hover:brightness-110 transition-all">
          {lang === 'it' ? 'Accetta tutto' : 'Aceptar todo'}
        </button>
        <button id="deny-privacy"
          class="flex-1 sm:flex-initial text-center cursor-pointer bg-transparent text-gray-500 border border-gray-200 text-xs font-semibold py-2 px-4 rounded-lg hover:bg-gray-50 transition-all">
          {lang === 'it' ? 'Rifiuta tutto' : 'Rechazar todo'}
        </button>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      var banner = document.getElementById('privacy-banner');
      var btnAccept = document.getElementById('accept-privacy');
      var btnDeny = document.getElementById('deny-privacy');
      if (!banner || !btnAccept || !btnDeny) return;

      var consent = localStorage.getItem('cookie-consent');
      if (!consent) {
        setTimeout(function() {
          banner.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none');
        }, 300);
      }

      btnAccept.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'accepted');
        banner.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');
        window.location.reload();
      });

      btnDeny.addEventListener('click', function() {
        localStorage.setItem('cookie-consent', 'denied');
        banner.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');
      });
    })();
  </script>
</body>
</html>