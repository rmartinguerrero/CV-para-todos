---
// src/pages/[lang]/index.astro
import { useTranslations, getAvailableLangs, type Lang, type UIKeys } from '../../i18n/ui';
import MinimalistLayout from '../../layouts/MinimalistLayout.astro';

// Componentes del currículum estructurado
import Header      from '../../components/Header.astro';
import Experience  from '../../components/Experience.astro';
import Education   from '../../components/Education.astro';
import Skills      from '../../components/Skills.astro';
import Projects    from '../../components/Projects.astro';
import SetupWizard from '../../components/SetupWizard.astro';
import Footer from '../../components/Footer.astro';

import resumeEs from '../../data/resume.es.json';
import resumeIt from '../../data/resume.it.json';
import resumeEn from '../../data/resume.en.json';

const resumes = { es: resumeEs, it: resumeIt, en: resumeEn };

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'it' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params as { lang: 'es' | 'it' | 'en' };
const resume = resumes[lang];
const strictT = useTranslations(lang);
const t = (key: string) => strictT(key as UIKeys);

const isEmpty = !resume?.basics?.name?.trim();
const availableLangs = getAvailableLangs(resumes);

// 📂 MAPEO DINÁMICO DE LAYOUTS PÚBLICOS
const layoutModules = import.meta.glob('../../layouts/*.astro', { eager: true });
const LAYOUTS_MAP = Object.entries(layoutModules).reduce((acc, [path, mod]: [string, any]) => {
  if (mod.templateMeta?.id) {
    acc[mod.templateMeta.id.toLowerCase()] = mod.default;
  }
  return acc;
}, {} as Record<string, any>);

const templateKey = (resume as any)?.meta?.template?.toLowerCase() || 'minimalist';
const DynamicLayout = LAYOUTS_MAP[templateKey] || MinimalistLayout;
---

{isEmpty ? (
  <SetupWizard availableLangs={['es', 'it', 'en']} defaultLang={lang} />
) : (
  <DynamicLayout
    title={`${resume.basics.name} — ${resume.basics.label}`}
    description={`CV of ${resume.basics.name}`}
    lang={lang}
    currentLang={lang}
    availableLangs={availableLangs}
    resume={resume}
    t={t}
  >
    <Header      resume={resume} lang={lang} t={t} availableLangs={availableLangs} />
    {resume.work?.length      > 0 && <Experience resume={resume} t={t} />}
    {resume.education?.length > 0 && <Education  resume={resume} t={t} />}
    {resume.skills?.length    > 0 && <Skills     resume={resume} t={t} />}
    {resume.projects?.length  > 0 && <Projects   resume={resume} t={t} />}
    <Footer lang={lang} />
  </DynamicLayout>
)}