---
// src/components/Projects.astro
interface Props {
  resume: any;
  t:      (key: string) => string;
}
const { resume, t } = Astro.props;
---

<section class="mb-10 print:mb-6" aria-labelledby="projects-heading">
  <h2
    id="projects-heading"
    class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-5 pb-2 border-b border-gray-100"
  >
    {t('section.projects')}
  </h2>

  <ul class="space-y-5">
    {resume.projects.filter((p: any) => p.name).map((project: any) => (
      <li class="min-w-0">
        <div class="flex flex-wrap items-baseline gap-x-2">
          <h3 class="font-semibold text-gray-900 break-words">{project.name}</h3>
          {project.url && (() => {
            try {
              const parsedUrl = new URL(project.url);
              return (
                <a 
                  href={project.url} 
                  target="_blank" 
                  rel="noopener noreferrer" 
                  class="text-sm text-gray-500 hover:text-brand-600 transition-colors inline-flex items-center gap-1 break-all"
                >
                  {parsedUrl.hostname} ↗
                </a>
              );
            } catch (e) {
              return (
                <span class="text-sm text-gray-400 italic break-words">
                  {project.url}
                </span>
              );
            }
          })()}
        </div>
        {project.description && (
          <p class="mt-1 text-sm text-gray-600 leading-relaxed break-words">{project.description}</p>
        )}
        {project.keywords?.length > 0 && (
          <ul class="mt-2 flex flex-wrap gap-1.5 min-w-0" aria-label="Tecnologías">
            {project.keywords.filter(Boolean).map((kw: string) => (
              <li class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full max-w-full break-words">
                {kw}
              </li>
            ))}
          </ul>
        )}
      </li>
    ))}
  </ul>
</section>
