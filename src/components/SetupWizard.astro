// FAQ
const faqs = {
  es: [
    { q: '¿Es realmente gratis?', a: 'Sí. Completamente gratis. Sin suscripciones, sin anuncios, sin planes de pago. El código es abierto y el CV se aloja en GitHub Pages, un servicio gratuito de GitHub.' },
