---
// src/components/SetupWizard.astro
import MinimalistLayout from '../layouts/MinimalistLayout.astro';
import { useTranslations, type Lang, languages, type UIKeys } from '../i18n/ui';

interface Props {
  availableLangs: string[];
  defaultLang: string;
}

const { defaultLang } = Astro.props;
const lang = defaultLang as Lang;

const strictT = useTranslations(lang);
const t = (key: string) => strictT(key as UIKeys);
---

<MinimalistLayout
  title={t('wizard.welcome')}
  description={t('wizard.subtitle')}
  lang={lang}
  currentLang={lang}
  availableLangs={['es', 'it', 'en']}
  resume={{}}
  t={t}
>
  <div class="min-h-screen bg-gradient-to-br from-gray-50 to-gray-100 flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8 font-sans">
    <div class="max-w-md w-full mx-auto bg-white rounded-2xl shadow-xl border border-gray-100 p-8 text-center space-y-6">
      
      <div class="flex justify-center gap-2 bg-gray-100 p-1 rounded-lg w-fit mx-auto text-xs">
        {Object.entries(languages).map(([code, label]) => (
          <a 
            href={`/${code}/`}
            class={`px-3 py-1 rounded transition-colors ${code === lang ? 'bg-blue-600 text-white shadow' : 'text-gray-500 hover:text-gray-900'}`}
          >
            {label} {/* <--- AQUÍ FALTABA POR CERRAR LA LLAVE DEL RECUADRO */}
          </a>
        ))}
      </div>

      <div class="space-y-2">
        <h1 class="text-2xl font-extrabold text-gray-900 tracking-tight sm:text-3xl">
          {t('wizard.welcome')}
        </h1>
        <p class="text-sm text-gray-500">
          {t('wizard.subtitle')}
        </p>
      </div>

      <div class="flex flex-col gap-3 pt-4">
        <a 
          href={`/${lang}/edit`}
          class="w-full inline-flex justify-center items-center py-3 px-4 border border-transparent text-sm font-medium rounded-xl text-white bg-blue-600 hover:bg-blue-700 transition-colors shadow-md"
        >
          ✨ {t('wizard.create')}
        </a>
        
        <button 
          id=\"oauth-trigger-btn\"
          class="w-full inline-flex justify-center items-center py-3 px-4 border border-gray-300 text-sm font-medium rounded-xl text-gray-700 bg-white hover:bg-gray-50 transition-colors shadow-sm"
        >
          🔑 {t('wizard.import')}
        </button>
      </div>

    </div>
  </div>
</MinimalistLayout>