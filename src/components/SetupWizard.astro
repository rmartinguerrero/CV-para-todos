---
// src/components/SetupWizard.astro
// Se muestra cuando los archivos JSON están vacíos (primer uso)
interface Props {
  lang: string;
  t:    (key: string) => string;
}
const { t } = Astro.props;
---

<!DOCTYPE html>
<html translate="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CV Para Todos — Configuración inicial</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
    rel="stylesheet"
  />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #f8fafc;
      color: #1e293b;
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 2rem 1rem;
    }
    .card {
      background: #fff;
      border: 1px solid #e2e8f0;
      border-radius: 16px;
      padding: 2.5rem 2rem;
      max-width: 520px;
      width: 100%;
      text-align: center;
    }
    .badge {
      display: inline-block;
      background: #f0f9ff;
      color: #0369a1;
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      margin-bottom: 1rem;
    }
    h1 { font-size: 1.5rem; font-weight: 600; margin: 0 0 0.5rem; }
    p  { color: #64748b; font-size: 0.9rem; line-height: 1.6; margin: 0 0 1.5rem; }
    .steps {
      text-align: left;
      background: #f8fafc;
      border-radius: 12px;
      padding: 1.25rem 1.5rem;
      margin-bottom: 1.75rem;
      list-style: none;
      counter-reset: step;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .steps li {
      counter-increment: step;
      display: grid;
      grid-template-columns: 1.75rem 1fr;
      gap: 0.5rem;
      align-items: start;
      font-size: 0.875rem;
      color: #334155;
    }
    .steps li::before {
      content: counter(step);
      background: #1e293b;
      color: #fff;
      width: 1.5rem;
      height: 1.5rem;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-size: 0.75rem;
      font-weight: 600;
      flex-shrink: 0;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: #1e293b;
      color: #fff;
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      padding: 0.65rem 1.4rem;
      border-radius: 10px;
      transition: background 0.15s;
    }
    .btn:hover { background: #0f172a; }
  </style>
</head>
<body>
  <div class="card">
    <span class="badge">Setup</span>
    <h1>CV Para Todos</h1>
    <p>Tu CV está casi listo. Solo necesitas completar dos pasos para publicarlo en internet de forma gratuita.</p>

    <ol class="steps">
      <li>{t('setup.step1')}</li>
      <li>{t('setup.step2')}</li>
    </ol>

    <a
      href="https://github.com/settings/pages"
      target="_blank"
      rel="noopener noreferrer"
      class="btn"
    >
      {t('setup.cta')}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
        <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
      </svg>
    </a>
  </div>
</body>
</html>
