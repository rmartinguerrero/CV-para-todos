<style>
  /* Animaciones fade-in on scroll */
  .fade-in {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .stagger-1 { transition-delay: 0.1s; }
  .stagger-2 { transition-delay: 0.2s; }
  .stagger-3 { transition-delay: 0.3s; }

  .stagger-item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  .stagger-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Step numbers scale-in on load */
  .step-number {
    animation: scaleIn 0.5s ease-out both;
  }
  @keyframes scaleIn {
    from { transform: scale(0.6); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  /* Card hover lift */
  .card-hover {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .card-hover:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -8px rgba(0,0,0,0.1);
  }

  /* FAQ chevron rotation */
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] summary {
    border-bottom: 1px solid #e5e7eb;
  }
</style>

<script define:vars={{ lang }}>
  const alerts = {
    es: { 
      success: "¡JSON importado con éxito para Español!", 
      error: "El archivo no contiene un JSON válido.",
      warning: "¡Cuidado! El nombre del archivo parece ser de otro idioma."
    },
    it: { 
      success: "JSON importato con successo per l'Italiano!", 
      error: "File JSON non valido.",
      warning: "Attenzione! Lingua errata nel file."
    },
    en: { 
      success: "JSON imported successfully!", 
      error: "Invalid JSON file.",
      warning: "Warning! Wrong language file."
    }
  };

  const currentAlerts = alerts[lang] || alerts.es;

  const importBtn = document.getElementById('wizard-import-btn');
  const importBtnBottom = document.getElementById('wizard-import-btn-bottom');
  const fileInput = document.getElementById('wizard-file-input');

  importBtn?.addEventListener('click', () => fileInput?.click());
  importBtnBottom?.addEventListener('click', () => fileInput?.click());

  fileInput?.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    const reader = new FileReader();

    reader.onload = (evt) => {
      try {
        const parsedJson = JSON.parse(evt.target.result);

        localStorage.setItem(
          `cv_backup_data_${lang}`,
          JSON.stringify(parsedJson)
        );

        alert(currentAlerts.success);
        window.location.href = `/${lang}/edit`;
      } catch {
        alert(currentAlerts.error);
      }
    };

    reader.readAsText(file);
  });

  // ✅ FIX ASTRO SAFE: NO DOMContentLoaded
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.fade-in, .stagger-item')
    .forEach(el => observer.observe(el));

  // ❌ REMOVE TS CASTING, vanilla JS safe
  document.querySelectorAll('.stagger-item')
    .forEach((el, i) => {
      (el.style).transitionDelay = `${0.1 + i * 0.08}s`;
    });
</script>

<!-- Cookie Consent + Google Analytics (RGPD) - LANDING -->
<script is:inline>
  (() => {
    const consent = localStorage.getItem('cookie-consent');
    if (consent !== 'accepted') return;

    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    window.gtag = gtag;

    gtag('js', new Date());
    gtag('config', 'G-R3TG90C8J5', { anonymize_ip: true });

    const gaScript = document.createElement('script');
    gaScript.async = true;
    gaScript.src = "https://www.googletagmanager.com/gtag/js?id=G-R3TG90C8J5";

    document.head.appendChild(gaScript);
  })();
</script>

<script is:inline>
(function() {
  const banner = document.getElementById('privacy-banner');
  const btnAccept = document.getElementById('accept-privacy');
  const btnDeny = document.getElementById('deny-privacy');

  if (!banner || !btnAccept || !btnDeny) return;

  const consent = localStorage.getItem('cookie-consent');

  // mostrar banner si no hay decisión
  if (!consent) {
    setTimeout(() => {
      banner.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none');
    }, 400);
  }

  btnAccept.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'accepted');

    banner.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');

    // activar GA solo si no estaba ya activo
    if (!window._gaLoaded) {
      window._gaLoaded = true;

      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;

      gtag('js', new Date());
      gtag('config', 'G-R3TG90C8J5', { anonymize_ip: true });

      const s = document.createElement('script');
      s.async = true;
      s.src = "https://www.googletagmanager.com/gtag/js?id=G-R3TG90C8J5";
      document.head.appendChild(s);
    }
  });

  btnDeny.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'denied');
