---
// src/components/SetupWizard.astro
import MinimalistLayout from '../layouts/MinimalistLayout.astro';
import { useTranslations, type Lang, languages, type UIKeys } from '../i18n/ui';
import Footer from './Footer.astro'

interface Props {
  availableLangs: string[];
  defaultLang: string;
}

const { defaultLang } = Astro.props;
const lang = defaultLang as Lang;

const strictT = useTranslations(lang);
const t = (key: string) => strictT(key as UIKeys);

// Contenido de beneficios traducido
const benefits = {
  es: [
    { icon: '🆓', title: 'Completamente Gratuito', desc: 'Sin suscripción, sin anuncios, sin restricciones. Publica tu CV sin pagar nada.' },
    { icon: '🔐', title: '100% Privacidad', desc: 'Tu CV vive en tu repositorio GitHub. Nadie más tiene acceso a tus datos.' },
    { icon: '⚡', title: 'Crea un CV profesional en minutos', desc: 'Generador No-Code. Solo rellena el formulario y publica al instante.' }
  ],
  it: [
    { icon: '🆓', title: 'Completamente Gratuito', desc: 'Nessun abbonamento, nessun annuncio, nessuna limitazione. Pubblica il tuo CV gratis.' },
    { icon: '🔐', title: '100% Privacy', desc: 'Il tuo CV vive nel tuo repository GitHub. Nessun altro ha accesso ai tuoi dati.' },
    { icon: '⚡', title: 'Crea un CV professionale in minuti', desc: 'Generatore No-Code. Compila il modulo e pubblica immediatamente.' }
  ],
  en: [
    { icon: '🆓', title: 'Completely Free', desc: 'No subscription, no ads, no restrictions. Publish your CV at no cost.' },
    { icon: '🔐', title: '100% Privacy', desc: 'Your CV lives in your GitHub repository. Nobody else has access to your data.' },
    { icon: '⚡', title: 'Create a professional CV in minutes', desc: 'No-Code generator. Just fill the form and publish instantly.' }
  ]
};

const steps = {
  es: [
    { num: '1', title: 'Conecta tu GitHub', desc: 'Autoriza la aplicación con tu cuenta de GitHub de forma segura.' },
    { num: '2', title: 'Rellena tus Datos', desc: 'Completa el formulario No-Code con tu experiencia y habilidades.' },
    { num: '3', title: 'Publica al instante en GitHub Pages', desc: 'Tu CV estará disponible en tu web personal (username.github.io).' }
  ],
  it: [
    { num: '1', title: 'Connetti il tuo GitHub', desc: 'Autorizza l\'app con il tuo account GitHub in modo sicuro.' },
    { num: '2', title: 'Compila i Tuoi Dati', desc: 'Completa il modulo No-Code con la tua esperienza e competenze.' },
    { num: '3', title: 'Pubblica immediatamente su GitHub Pages', desc: 'Il tuo CV sarà disponibile sulla tua pagina personale (username.github.io).' }
  ],
  en: [
    { num: '1', title: 'Connect your GitHub', desc: 'Authorize the app with your GitHub account securely.' },
    { num: '2', title: 'Fill in Your Data', desc: 'Complete the No-Code form with your experience and skills.' },
    { num: '3', title: 'Publish instantly on GitHub Pages', desc: 'Your CV will be available on your personal web (username.github.io).' }
  ]
};

// How It Works detail (4 steps)
const howSteps = {
  es: [
    { num: '1', icon: '🔗', title: t('wizard.howStep1Title'), desc: t('wizard.howStep1Desc') },
    { num: '2', icon: '✏️', title: t('wizard.howStep2Title'), desc: t('wizard.howStep2Desc') },
    { num: '3', icon: '🚀', title: t('wizard.howStep3Title'), desc: t('wizard.howStep3Desc') },
    { num: '4', icon: '🔗', title: t('wizard.howStep4Title'), desc: t('wizard.howStep4Desc') }
  ],
  it: [
    { num: '1', icon: '🔗', title: t('wizard.howStep1Title'), desc: t('wizard.howStep1Desc') },
    { num: '2', icon: '✏️', title: t('wizard.howStep2Title'), desc: t('wizard.howStep2Desc') },
    { num: '3', icon: '🚀', title: t('wizard.howStep3Title'), desc: t('wizard.howStep3Desc') },
    { num: '4', icon: '🔗', title: t('wizard.howStep4Title'), desc: t('wizard.howStep4Desc') }
  ],
  en: [
    { num: '1', icon: '🔗', title: t('wizard.howStep1Title'), desc: t('wizard.howStep1Desc') },
    { num: '2', icon: '✏️', title: t('wizard.howStep2Title'), desc: t('wizard.howStep2Desc') },
    { num: '3', icon: '🚀', title: t('wizard.howStep3Title'), desc: t('wizard.howStep3Desc') },
    { num: '4', icon: '🔗', title: t('wizard.howStep4Title'), desc: t('wizard.howStep4Desc') }
  ]
};

// Results cards
const results = {
  es: [
    { icon: '🌐', title: 'Web pública profesional', desc: 'Tu CV funciona como sitio web, accesible desde cualquier dispositivo. Sin necesidad de alojamiento adicional.' },
    { icon: '📄', title: 'PDF exportable', desc: 'Diseñado para impresión. Descarga o imprime tu CV directamente desde el navegador con un solo clic.' },
    { icon: '⚡', title: 'GitHub Pages gratuito', desc: 'Alojamiento rápido y sin costo. Usamos GitHub Pages para publicar tu CV sin servidores ni configuraciones.' },
    { icon: '🔐', title: 'Propiedad total de tus datos', desc: 'Tu información vive en tu repositorio GitHub. Siempre bajo tu control, nunca en servidores de terceros.' },
    { icon: '🌍', title: 'Soporte multilenguaje', desc: 'Crea tu CV en Español, Italiano o Inglés. Cambia de idioma al instante sin perder tu progreso.' }
  ],
  it: [
    { icon: '🌐', title: 'Sito web professionale pubblico', desc: 'Il tuo CV funziona come sito web accessibile da qualsiasi dispositivo. Senza bisogno di hosting aggiuntivo.' },
    { icon: '📄', title: 'PDF esportabile', desc: 'Progettato per la stampa. Scarica o stampa il tuo CV direttamente dal browser con un clic.' },
    { icon: '⚡', title: 'GitHub Pages gratuito', desc: 'Hosting veloce e senza costi. Usiamo GitHub Pages per pubblicare il tuo CV senza server né configurazioni.' },
    { icon: '🔐', title: 'Proprietà totale dei tuoi dati', desc: 'Le tue informazioni vivono nel tuo repository GitHub. Sempre sotto il tuo controllo, mai su server di terze parti.' },
    { icon: '🌍', title: 'Supporto multilingua', desc: 'Crea il tuo CV in Spagnolo, Italiano o Inglese. Cambia lingua istantaneamente senza perdere i progressi.' }
  ],
  en: [
    { icon: '🌐', title: 'Public professional website', desc: 'Your CV works as a website accessible from any device. No additional hosting needed.' },
    { icon: '📄', title: 'Exportable PDF', desc: 'Designed for printing. Download or print your CV directly from the browser with one click.' },
    { icon: '⚡', title: 'Free GitHub Pages hosting', desc: 'Fast, cost-free hosting. We use GitHub Pages to publish your CV with no servers or setup.' },
    { icon: '🔐', title: 'Full data ownership', desc: 'Your information lives in your GitHub repository. Always under your control, never on third-party servers.' },
    { icon: '🌍', title: 'Multi-language support', desc: 'Create your CV in Spanish, Italian or English. Switch languages instantly without losing your progress.' }
  ]
};

// FAQ
const faqs = {
  es: [
    { q: '¿Es realmente gratis?', a: 'Sí, completamente gratis. Sin suscripciones, sin anuncios, sin planes de pago. El código es abierto y tu CV se aloja en GitHub Pages, un servicio gratuito de GitHub.' },
    { q: '¿Necesito saber programar para usarlo?', a: 'No. El editor es 100% No-Code: simplemente rellenas formularios con tus datos y el CV se genera automáticamente. No necesitas tocar una línea de código.' },
    { q: '¿Dónde se almacena la información de mi CV?', a: 'En tu repositorio personal de GitHub. Solo tú tienes acceso de escritura. La aplicación solo puede crear y actualizar archivos en ese repositorio específico.' },
    { q: '¿Puedo eliminar mi CV después de publicarlo?', a: 'Sí. Puedes borrar el repositorio desde GitHub en cualquier momento. Tu CV dejará de estar disponible inmediatamente al eliminar el repositorio.' },
    { q: '¿Puedo editar mi CV después de publicarlo?', a: 'Sí. Vuelve al editor, modifica tus datos y vuelve a publicar. Tu sitio web se actualiza al instante conservando la misma URL.' }
  ],
  it: [
    { q: 'È veramente gratuito?', a: 'Sì, completamente gratuito. Nessun abbonamento, nessuna pubblicità, nessun piano a pagamento. Il codice è aperto e il tuo CV è ospitato su GitHub Pages, un servizio gratuito di GitHub.' },
    { q: 'Devo saper programmare per usarlo?', a: 'No. L\'editor è 100% No-Code: basta compilare i moduli con i tuoi dati e il CV viene generato automaticamente. Non serve scrivere una riga di codice.' },
    { q: 'Dove vengono archiviati i dati del mio CV?', a: 'Nel tuo repository personale di GitHub. Solo tu hai accesso in scrittura. L\'app può solo creare e aggiornare file in quel repository specifico.' },
    { q: 'Posso eliminare il mio CV dopo la pubblicazione?', a: 'Sì. Puoi cancellare il repository da GitHub in qualsiasi momento. Il tuo CV smetterà di essere disponibile immediatamente.' },
    { q: 'Posso modificare il mio CV dopo la pubblicazione?', a: 'Sì. Torna all\'editor, modifica i tuoi dati e ripubblica. Il tuo sito web si aggiorna istantaneamente mantenendo lo stesso URL.' }
  ],
  en: [
    { q: 'Is it really free?', a: 'Yes, completely free. No subscriptions, no ads, no paid plans. The code is open source and your CV is hosted on GitHub Pages, a free service from GitHub.' },
    { q: 'Do I need coding skills?', a: 'No. The editor is 100% No-Code: just fill in forms with your data and the CV is generated automatically. No need to write a single line of code.' },
    { q: 'Where is my CV data stored?', a: 'In your personal GitHub repository. Only you have write access. The app can only create and update files in that specific repository.' },
    { q: 'Can I delete my CV after publishing?', a: 'Yes. You can delete the repository from GitHub at any time. Your CV will stop being available immediately.' },
    { q: 'Can I edit my CV after publishing?', a: 'Yes. Return to the editor, update your data and publish again. Your website updates instantly while keeping the same URL.' }
  ]
};

const currentBenefits = benefits[lang] || benefits.es;
const currentSteps = steps[lang] || steps.es;
const currentHowSteps = howSteps[lang] || howSteps.es;
const currentResults = results[lang] || results.es;
const currentFaqs = faqs[lang] || faqs.es;
---

<MinimalistLayout
  title={t('wizard.welcome')}
  description={t('wizard.subtitle')}
  lang={lang}
  currentLang={lang}
  availableLangs={['es', 'it', 'en']}
  resume={{}}
  t={t}
>
  <div class="min-h-screen bg-gradient-to-br from-slate-50 via-white to-slate-50 flex flex-col font-sans overflow-hidden">

    <!-- Top Nav Bar -->
    <nav class="sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-gray-200 py-2.5 px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto flex justify-between items-center">
        <a href={`/${lang}/`} class="flex items-center gap-2 no-underline">
          <span class="text-lg">📋</span>
          <span class="text-sm font-bold text-gray-800">{t('brand.name')}</span>
        </a>
        <div class="inline-flex rounded-full bg-gray-100 p-1 border border-gray-200 gap-1">
            {['es', 'it', 'en'].map((l) => (
              <a
                href={`/${l}/`}
                class={`px-2 sm:px-3 py-1.5 rounded-full text-xs font-semibold transition-all no-underline ${
                  lang === l
                    ? 'bg-white text-gray-900 shadow-sm border border-gray-300'
                    : 'text-gray-600 hover:text-gray-900'
                }`}
              >
                <span>{l === 'es' ? '🇪🇸' : l === 'it' ? '🇮🇹' : '🇺🇸'}</span>
                <span class="hidden sm:inline ml-1">
                  {languages[l as Lang]}
                </span>
              </a>
            ))}
          </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <div class="flex-1 flex flex-col justify-center py-12 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto w-full space-y-12">

        <!-- SEO hidden H2s -->
        <h2 class="sr-only">{t('wizard.tagline')}</h2>
        <h2 class="sr-only">Free CV builder online — JSON Resume generator</h2>
        <h2 class="sr-only">GitHub resume builder — CV online gratis</h2>

        <!-- Header Hero -->
        <div class="text-center space-y-4 fade-in">
          <div class="inline-block">
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-50 border border-blue-200 text-blue-700 text-sm font-semibold">
              <span class="text-lg">✨</span>
              {t('wizard.tagline')}
            </div>
          </div>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-900 tracking-tight">
            {t('wizard.welcome')}
          </h1>
          <p class="text-lg sm:text-xl text-gray-600 max-w-2xl mx-auto">
            {t('wizard.subtitle')}
          </p>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center fade-in stagger-1">
          <a 
            href={`/${lang}/edit`}
            class="inline-flex justify-center items-center py-3.5 px-8 border border-transparent text-base font-semibold rounded-xl text-white bg-blue-600 hover:bg-blue-700 transition-all shadow-lg hover:shadow-xl no-underline card-hover"
          >
            <span class="mr-2">✨</span>
            {t('wizard.create')}
          </a>
          
          <button 
            type="button"
            id="wizard-import-btn"
            class="inline-flex justify-center items-center py-3.5 px-8 border border-gray-300 text-base font-semibold rounded-xl text-gray-700 bg-white hover:bg-gray-50 transition-all shadow-md hover:shadow-lg cursor-pointer card-hover"
          >
            <span class="mr-2">📥</span>
            {t('wizard.import')}
          </button>
        </div>

        <!-- Beneficios -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 py-8 fade-in stagger-2">
          {currentBenefits.map((benefit) => (
            <div class="p-6 rounded-xl border border-gray-200 bg-white transition-all card-hover">
              <div class="text-3xl mb-3">{benefit.icon}</div>
              <h3 class="text-lg font-bold text-gray-900 mb-2">{benefit.title}</h3>
              <p class="text-sm text-gray-600">{benefit.desc}</p>
            </div>
          ))}
        </div>

        <!-- 3 Pasos Clave -->
        <div class="py-8 space-y-8 fade-in stagger-3">
          <h2 class="text-3xl font-bold text-gray-900 text-center">
            {lang === 'es' ? '3 Pasos Simples' : lang === 'it' ? '3 Semplici Passi' : '3 Simple Steps'}
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {currentSteps.map((step, idx) => (
              <div class="relative">
                {/* Conector visual (solo en desktop) */}
                {idx < 2 && (
                  <div class="hidden md:block absolute top-12 right-0 w-full h-1 bg-gradient-to-r from-blue-300 to-transparent -left-1/2 -z-10" />
                )}
                
                <div class="flex flex-col items-center text-center">
                  <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 text-white text-2xl font-bold shadow-lg mb-4 step-number">
                    {step.num}
                  </div>
                  <h3 class="text-xl font-bold text-gray-900 mb-2">{step.title}</h3>
                  <p class="text-sm text-gray-600">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- How It Works (detallado) -->
        <div class="py-8 space-y-8 fade-in">
          <h2 class="text-3xl font-bold text-gray-900 text-center">
            {t('wizard.howTitle')}
          </h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            {currentHowSteps.map((step, idx) => (
              <div class="relative card-hover stagger-item">
                <div class="flex flex-col items-center text-center p-5 rounded-xl border border-gray-200 bg-white transition-all h-full">
                  <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 text-white text-xl font-bold shadow-lg mb-4 step-number">
                    {step.num}
                  </div>
                  <div class="text-2xl mb-2">{step.icon}</div>
                  <h3 class="text-base font-bold text-gray-900 mb-2">{step.title}</h3>
                  <p class="text-xs text-gray-600">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- What You Get -->
        <div class="py-8 space-y-8 fade-in">
          <h2 class="text-3xl font-bold text-gray-900 text-center">
            {t('wizard.resultsTitle')}
          </h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {currentResults.map((result) => (
              <div class="p-6 rounded-xl border border-gray-200 bg-white transition-all card-hover stagger-item">
                <div class="text-3xl mb-3">{result.icon}</div>
                <h3 class="text-base font-bold text-gray-900 mb-2">{result.title}</h3>
                <p class="text-sm text-gray-600">{result.desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- FAQ -->
        <div class="py-8 space-y-8 fade-in">
          <h2 class="text-3xl font-bold text-gray-900 text-center">
            {t('wizard.faqTitle')}
          </h2>
          
          <div class="max-w-2xl mx-auto space-y-3">
            {currentFaqs.map((faq, idx) => (
              <details class="group rounded-xl border border-gray-200 bg-white overflow-hidden card-hover stagger-item">
                <summary class="flex items-center justify-between p-4 cursor-pointer list-none text-sm font-semibold text-gray-900 hover:bg-gray-50 transition-colors">
                  {faq.q}
                  <span class="text-gray-400 transition-transform duration-300 group-open:rotate-180">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </span>
                </summary>
                <div class="px-4 pb-4 text-sm text-gray-600 leading-relaxed">
                  {faq.a}
                </div>
              </details>
            ))}
          </div>
        </div>

        <!-- Info Footer -->
        <div class="mt-8 p-6 rounded-xl bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 text-center fade-in">
          <p class="text-sm text-gray-700 mb-3">
            {lang === 'es' 
              ? '📥 Recomendado: Sube un archivo' 
              : lang === 'it' 
              ? '📥 Consigliato: Carica un file' 
              : '📥 Recommended: Upload a file'}
            <code class="bg-white px-2 py-1 rounded border border-gray-300 font-mono text-xs font-semibold text-blue-600 ml-1">resume.{lang}.json</code>
          </p>
          <p class="text-xs text-gray-600">
            {lang === 'es'
              ? 'Puedes descargar tu CV actual en JSON desde cualquier editor y reimportarlo aquí.'
              : lang === 'it'
              ? 'Puoi scaricare il tuo CV attuale in JSON da qualsiasi editor e reimportarlo qui.'
              : 'You can download your current CV in JSON from any editor and re-import it here.'}
          </p>
        </div>

      </div>
    </div>
  </div>

  <!-- Input file oculto -->
  <input type="file" id="wizard-file-input" accept=".json" class="hidden" />
<Footer lang={lang} />

<!-- Cookie Consent Banner (Landing) -->
<div id="privacy-banner"
  class="fixed bottom-3 left-3 right-3 sm:left-6 sm:bottom-6 sm:right-auto sm:max-w-md 
  bg-white border border-gray-200 p-4 rounded-xl shadow-2xl z-50 
  opacity-0 translate-y-8 pointer-events-none flex flex-col gap-3 
  transition-all duration-500 ease-out">

  <div>
    <h4 class="text-sm font-bold text-gray-900 mb-1">
      {lang === 'it' ? 'Uso dei Cookie' : lang === 'es' ? 'Uso de Cookies' : 'Cookie Usage'}
    </h4>

    <p class="text-xs text-gray-500 leading-relaxed">
      {lang === 'it'
        ? 'Usiamo cookie per analisi e miglioramento dell’esperienza.'
        : lang === 'es'
        ? 'Usamos cookies para analizar el rendimiento y mejorar la experiencia.'
        : 'We use cookies to analyze performance and improve experience.'}
      <a href={`/${lang}/cookie-policy`} class="text-blue-600 underline font-semibold">Policy</a>
      {' · '}
      <a href={`/${lang}/privacy-policy`} class="text-blue-600 underline font-semibold">Privacy</a>
    </p>
  </div>

  <div class="flex gap-2 justify-end">
    <button id="accept-privacy"
      class="bg-blue-600 text-white text-xs font-semibold py-2 px-4 rounded-lg hover:brightness-110">
      {lang === 'it' ? 'Accetta tutto' : lang === 'es' ? 'Aceptar' : 'Accept'}
    </button>

    <button id="deny-privacy"
      class="bg-gray-100 text-gray-600 text-xs font-semibold py-2 px-4 rounded-lg hover:bg-gray-200">
      {lang === 'it' ? 'Rifiuta' : lang === 'es' ? 'Rechazar' : 'Reject'}
    </button>
  </div>
</div>
</MinimalistLayout>

<style>
  /* Animaciones fade-in on scroll */
  .fade-in {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .stagger-1 { transition-delay: 0.1s; }
  .stagger-2 { transition-delay: 0.2s; }
  .stagger-3 { transition-delay: 0.3s; }

  .stagger-item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease-out, transform 0.5s ease-out;
  }
  .stagger-item.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Step numbers scale-in on load */
  .step-number {
    animation: scaleIn 0.5s ease-out both;
  }
  @keyframes scaleIn {
    from { transform: scale(0.6); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  /* Card hover lift */
  .card-hover {
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .card-hover:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px -8px rgba(0,0,0,0.1);
  }

  /* FAQ chevron rotation */
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
  details[open] summary {
    border-bottom: 1px solid #e5e7eb;
  }
</style>

<script define:vars={{ lang }}>
  const alerts = {
    es: { 
      success: "¡JSON importado con éxito para Español!", 
      error: "El archivo no contiene un JSON válido.",
      warning: "¡Cuidado! El nombre del archivo parece ser de otro idioma."
    },
    it: { 
      success: "JSON importato con successo per l'Italiano!", 
      error: "File JSON non valido.",
      warning: "Attenzione! Lingua errata nel file."
    },
    en: { 
      success: "JSON imported successfully!", 
      error: "Invalid JSON file.",
      warning: "Warning! Wrong language file."
    }
  };

  const currentAlerts = alerts[lang] || alerts.es;

  const importBtn = document.getElementById('wizard-import-btn');
  const fileInput = document.getElementById('wizard-file-input');

  importBtn?.addEventListener('click', () => fileInput?.click());

  fileInput?.addEventListener('change', (e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    const reader = new FileReader();

    reader.onload = (evt) => {
      try {
        const parsedJson = JSON.parse(evt.target.result);

        localStorage.setItem(
          `cv_backup_data_${lang}`,
          JSON.stringify(parsedJson)
        );

        alert(currentAlerts.success);
        window.location.href = `/${lang}/edit`;
      } catch {
        alert(currentAlerts.error);
      }
    };

    reader.readAsText(file);
  });

  // ✅ FIX ASTRO SAFE: NO DOMContentLoaded
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.fade-in, .stagger-item')
    .forEach(el => observer.observe(el));

  // ❌ REMOVE TS CASTING, vanilla JS safe
  document.querySelectorAll('.stagger-item')
    .forEach((el, i) => {
      (el.style).transitionDelay = `${0.1 + i * 0.08}s`;
    });
</script>

