---
// src/components/SetupWizard.astro
import MinimalistLayout from '../layouts/MinimalistLayout.astro';
import { useTranslations, type Lang, languages, type UIKeys } from '../i18n/ui';
import Footer from './Footer.astro'

interface Props {
  availableLangs: string[];
  defaultLang: string;
}

const { defaultLang } = Astro.props;
const lang = defaultLang as Lang;

const strictT = useTranslations(lang);
