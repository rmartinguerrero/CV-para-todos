<script is:inline>
(function() {
  const banner = document.getElementById('privacy-banner');
  const btnAccept = document.getElementById('accept-privacy');
  const btnDeny = document.getElementById('deny-privacy');

  if (!banner || !btnAccept || !btnDeny) return;

  const consent = localStorage.getItem('cookie-consent');

  // mostrar banner si no hay decisión
  if (!consent) {
    setTimeout(() => {
      banner.classList.remove('opacity-0', 'translate-y-8', 'pointer-events-none');
    }, 400);
  }

  btnAccept.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'accepted');

    banner.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');

    // activar GA solo si no estaba ya activo
    if (!window._gaLoaded) {
      window._gaLoaded = true;

      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;

      gtag('js', new Date());
      gtag('config', 'G-R3TG90C8J5', { anonymize_ip: true });

      const s = document.createElement('script');
      s.async = true;
      s.src = "https://www.googletagmanager.com/gtag/js?id=G-R3TG90C8J5";
      document.head.appendChild(s);
    }
  });

  btnDeny.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'denied');
    banner.classList.add('opacity-0', 'translate-y-8', 'pointer-events-none');
  });
})();
</script>