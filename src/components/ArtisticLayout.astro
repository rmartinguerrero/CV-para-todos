---
// src/components/ArtisticLayout.astro
interface Props {
  resumeData: any;
}
const { resumeData } = Astro.props;
const { basics, education, work, projects, skills } = resumeData || {};
---
<div class="p-10 max-w-4xl mx-auto bg-amber-50 text-stone-800 font-sans shadow-lg rounded-3xl border border-amber-100">
  <header class="text-center mb-10">
    <h1 class="text-4xl font-bold font-serif italic text-amber-900 tracking-wide">{basics?.name}</h1>
    <div class="w-16 h-0.5 bg-amber-700 mx-auto my-3"></div>
    <p class="text-xs tracking-widest uppercase text-stone-500 font-medium">{basics?.label}</p>
    <p class="text-xs italic text-stone-400 mt-2">{basics?.email} {basics?.phone && `| ${basics.phone}`}</p>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
    <div class="md:col-span-2 space-y-6">
      {work && work.length > 0 && (
        <section>
          <h2 class="font-serif text-lg font-bold italic text-amber-900 mb-4 border-b border-amber-200/60 pb-1">Trayectoria Profesional</h2>
          <div class="space-y-6">
            {work.map((w: any) => (
              <div>
                <h3 class="text-sm font-bold text-stone-700">{w.position}</h3>
                <p class="text-xs text-amber-800 italic">{w.name} — <span class="text-stone-400 not-italic">{w.startDate} a {w.endDate || 'Presente'}</span></p>
                <p class="text-xs text-stone-600 mt-2 leading-relaxed font-serif">{w.summary}</p>
              </div>
            ))}
          </div>
        </section>
      )}
    </div>

    <div class="space-y-6">
      {skills && skills.length > 0 && (
        <section class="bg-amber-100/50 p-4 rounded-2xl border border-amber-200/40">
          <h2 class="font-serif text-sm font-bold italic text-amber-900 mb-3">Destrezas</h2>
          <div class="flex flex-wrap gap-1.5">
            {skills.flatMap((s: any) => s.keywords || []).map((k: string) => (
              <span class="text-xs text-stone-700 bg-white px-2 py-0.5 rounded-full border border-stone-200 shadow-sm">
                {k}
              </span>
            ))}
          </div>
        </section>
      )}
    </div>
  </div>
</div>
