---
// src/components/Footer.astro
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-gray-200 bg-white print:hidden">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8 text-center text-sm text-gray-500">

    <!-- Legal links -->
    <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 mb-4">
      <a href={`/${lang}/cookie-policy`} class="hover:text-gray-700 underline underline-offset-2">
        {lang === 'it'
          ? 'Cookie Policy'
          : lang === 'en'
          ? 'Cookie Policy'
          : 'Política de Cookies'}
      </a>

      <span class="text-gray-300 select-none">|</span>

      <a href={`/${lang}/privacy-policy`} class="hover:text-gray-700 underline underline-offset-2">
        {lang === 'it'
          ? 'Informativa sulla Privacy'
          : lang === 'en'
          ? 'Privacy Policy'
          : 'Política de Privacidad'}
      </a>
    </nav>

    <!-- Author -->
    <p class="mb-2">
      <a
        href="https://raulmguerrero.com"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gray-700 underline underline-offset-2"
      >
        {lang === 'it'
          ? 'Un progetto di RaulMGuerrero'
          : lang === 'en'
          ? 'A project by RaulMGuerrero'
          : 'Un proyecto de RaulMGuerrero'}
      </a>
    </p>

    <!-- GitHub Repository -->
    <p class="mb-2">
      <a
        href="https://github.com/rmartinguerrero/CV-para-todos"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-gray-700 underline underline-offset-2"
      >
        {lang === 'it'
          ? 'Puoi vedere il repository su GitHub con il link al progetto open source'
          : lang === 'en'
          ? 'You can see the repository on GitHub with the link to the open source project'
          : 'Puedes ver el repositorio en GitHub con el enlace al proyecto open source'}
      </a>
    </p>

    <!-- Copyright -->
    <p>
      &copy; {year} ·
      {lang === 'it'
        ? 'Tutti i diritti riservati'
        : lang === 'en'
        ? 'All rights reserved'
        : 'Todos los derechos reservados'}
    </p>

  </div>
</footer>