---
// src/components/Skills.astro
interface Props {
  resume: any;
  t:      (key: string) => string;
}
const { resume } = Astro.props;

// Detectamos el idioma actual desde la URL de forma robusta
const urlLang = Astro.url.pathname.split('/').filter(Boolean)[0] || 'es';

const labels = {
  es: { skills: 'Habilidades', languages: 'Idiomas' },
  it: { skills: 'Competenze', languages: 'Lingue' },
  en: { skills: 'Skills', languages: 'Languages' }
}[urlLang as 'es' | 'it' | 'en'] || { skills: 'Habilidades', languages: 'Idiomas' };
---

<section class="mb-10 print:mb-6" aria-labelledby="skills-heading">
  <h2
    id="skills-heading"
    class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-5 pb-2 border-b border-gray-100"
  >
    {labels.skills}
  </h2>

  <div class="flex flex-wrap gap-2">
    {resume.skills && resume.skills.filter((s: any) => s.name).map((skill: any) => (
      <span class="text-xs font-medium bg-gray-100 text-gray-700 px-3 py-1 rounded-full border border-gray-200/60 shadow-xs">
        {skill.name}
      </span>
    ))}
  </div>

  {resume.languages?.length > 0 && (
    <div class="mt-6">
      <h3 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-3">
        {labels.languages}
      </h3>
      <ul class="flex flex-wrap gap-x-4 gap-y-1">
        {resume.languages.filter((l: any) => l.language).map((langObj: any) => (
          <li class="text-sm text-gray-700">
            <span class="font-medium">{langObj.language}</span>
            {langObj.fluency && <span class="text-gray-400"> · {langObj.fluency}</span>}
          </li>
        ))}
      </ul>
    </div>
  )}
</section>