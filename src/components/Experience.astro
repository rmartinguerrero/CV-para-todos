---
// src/components/Experience.astro
interface Props {
  resume: any;
  t:      (key: string) => string;
}
const { resume, t } = Astro.props;
---

<section class="mb-10 print:mb-6" aria-labelledby="experience-heading">
  <h2
    id="experience-heading"
    class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-5 pb-2 border-b border-gray-100"
  >
    {t('section.experience')}
  </h2>

  <ol class="space-y-6">
    {resume.work.filter((job: any) => job.name).map((job: any) => (
      <li class="grid sm:grid-cols-[1fr_auto] gap-x-6">
        <div>
          <div class="flex flex-wrap items-baseline gap-x-2">
            <h3 class="font-semibold text-gray-900">{job.position}</h3>
            {job.url ? (
              <a
                href={job.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-gray-500 hover:text-gray-900 transition-colors"
                aria-label={`${t('label.viewCompany')} ${job.name}`}
              >
                {job.name} ↗
              </a>
            ) : (
              <span class="text-sm text-gray-500">{job.name}</span>
            )}
          </div>
          {job.summary && (
            <p class="mt-1.5 text-sm text-gray-600 leading-relaxed">{job.summary}</p>
          )}
          {job.highlights?.length > 0 && (
            <ul class="mt-2 space-y-0.5 text-sm text-gray-600 list-disc list-inside">
              {job.highlights.filter(Boolean).map((h: string) => (
                <li>{h}</li>
              ))}
            </ul>
          )}
        </div>
        <time class="text-xs text-gray-400 whitespace-nowrap sm:text-right mt-0.5">
          {job.startDate}
          {job.startDate && ' — '}
          {job.endDate || (job.startDate ? t('label.present') : '')}
        </time>
      </li>
    ))}
  </ol>
</section>
