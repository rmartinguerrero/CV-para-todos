# Copiar este archivo a .env.local y rellenar con tus valores
# NUNCA commits .env.local a git (añadido a .gitignore)

# ============================================================================
# CONFIGURACIÓN DE GITHUB OAUTH
# ============================================================================
# Instrucciones para obtener estos valores:
# 1. Ir a https://github.com/settings/developers -> OAuth Apps -> New OAuth App
# 2. Rellenar:
#    - Application name: "CV para Todos" (o tu nombre)
#    - Homepage URL: tu-dominio.com (ej: https://localhost:3000 para desarrollo)
#    - Authorization callback URL: https://tu-dominio.com/.netlify/functions/auth-callback
# 3. Copiar Client ID y generar nuevo Client Secret
# 4. Rellenar los valores abajo:

GITHUB_CLIENT_ID=your_client_id_from_github
GITHUB_CLIENT_SECRET=your_client_secret_from_github
GITHUB_REDIRECT_URI=https://tu-dominio.com/.netlify/functions/auth-callback
#
# Para desarrollo local con Netlify CLI, usa el callback local:
# GITHUB_REDIRECT_URI=http://localhost:8888/.netlify/functions/auth-callback

# ============================================================================
# CONFIGURACIÓN DE NETLIFY
# ============================================================================
# Estas variables se configuran en el dashboard de Netlify:
# https://app.netlify.com/sites/YOUR_SITE/settings/deploys

# URL de despliegue (se rellena automáticamente en Netlify)
DEPLOY_URL=http://localhost:3000

# Idioma por defecto de tu aplicación
# Si prefieres dejar que la app detecte el idioma del navegador,
# puedes omitir esta variable en producción.
DEFAULT_LANG=es

# ============================================================================
# CONFIGURACIÓN DEL REPOSITORIO BASE (OPCIONAL)
# ============================================================================
# Si quieres usar un repositorio base diferente para hacer fork
# BASE_REPO=tu-usuario/cv-para-todos

# ============================================================================
# DESARROLLO LOCAL
# ============================================================================
# Para desarrollo local con Netlify CLI:
# npx netlify-cli dev
# 
# Las variables de entorno se cargarán automáticamente del archivo .env.local
